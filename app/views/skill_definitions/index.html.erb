<% content_for :page_title, "Skills" %>
<div class="mb-5 flex justify-between">
  <%= form_with url: import_skills_path, method: :post, class: "flex flex-1 gap-2" do %>
    <%= text_area_tag :catalog_yaml, nil, rows: 1, placeholder: "Paste skill YAML", class: "app-input max-w-lg" %>
    <%= submit_tag "Import", class: "app-btn app-btn-muted" %>
  <% end %>
  <%= link_to "New skill", new_skill_path, class: "app-btn app-btn-primary" %>
</div>
<section class="app-card p-5">
  <table class="app-table">
    <thead><tr><th>Name</th><th>Category</th><th>Actions</th><th>Objective</th></tr></thead>
    <tbody>
      <% @skills.each do |skill| %>
        <tr>
          <td><%= link_to skill.name, skill_path(skill), class: "text-foreground hover:text-foreground" %></td>
          <td><%= skill.category %></td>
          <td><%= skill.action_definitions.size %></td>
          <td><%= skill.objective_template.present? ? "templated" : "custom" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
