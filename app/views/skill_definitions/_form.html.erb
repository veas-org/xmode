<%= form_with model: skill_definition,
      url: skill_definition.persisted? ? release_skill_path(skill_definition) : skills_path,
      method: :post,
      class: "space-y-4" do |form| %>
  <%= render "shared/form_errors", object: skill_definition %>
  <div class="grid gap-4 sm:grid-cols-3">
    <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input", required: true %></div>
    <div><%= form.label :key, class: "app-label" %><%= form.text_field :key, class: "app-input", required: true %></div>
    <div>
      <%= form.label :version, class: "app-label" %>
      <%= form.text_field :version,
            class: "app-input",
            required: true,
            placeholder: "1.0.0",
            readonly: skill_definition.persisted? %>
    </div>
  </div>
  <div><%= form.label :category, class: "app-label" %><%= form.select :category, SkillDefinition::CATEGORIES, {}, class: "app-input" %></div>
  <%= render "shared/markdown_editor",
        form: form,
        field: :description,
        label: "Description",
        rows: 5,
        placeholder: "What this skill does, when to use it, and what evidence it returns." %>
  <%= render "shared/markdown_editor",
        form: form,
        field: :instructions,
        label: "Instructions",
        rows: 8,
        placeholder: "Objective handling, planning behavior, guardrails, and output rules." %>
  <div class="grid gap-4 sm:grid-cols-2">
    <%= render "shared/markdown_editor", form: form, field: :objective_template, label: "Objective template", rows: 5 %>
    <%= render "shared/markdown_editor", form: form, field: :plan_template, label: "Plan template", rows: 5 %>
  </div>
  <div>
    <%= label_tag "skill_definition_best_practices_text", "Best practices", class: "app-label" %>
    <%= text_area_tag "skill_definition[best_practices_text]", skill_definition.best_practices.to_a.join("\n"), rows: 5, class: "app-textarea" %>
  </div>
  <div class="grid gap-4 sm:grid-cols-2">
    <div><%= label_tag "skill_definition_input_schema_json", "Input schema JSON", class: "app-label" %><%= text_area_tag "skill_definition[input_schema_json]", JSON.pretty_generate(skill_definition.input_schema.presence || {}), rows: 8, class: "app-textarea font-mono text-xs" %></div>
    <div><%= label_tag "skill_definition_output_schema_json", "Output schema JSON", class: "app-label" %><%= text_area_tag "skill_definition[output_schema_json]", JSON.pretty_generate(skill_definition.output_schema.presence || {}), rows: 8, class: "app-textarea font-mono text-xs" %></div>
  </div>
  <div><%= label_tag "skill_definition_metadata_json", "Metadata JSON", class: "app-label" %><%= text_area_tag "skill_definition[metadata_json]", JSON.pretty_generate(skill_definition.metadata.presence || {}), rows: 5, class: "app-textarea font-mono text-xs" %></div>
  <% if skill_definition.persisted? %>
    <div class="catalog-source-note">
      <div class="flex min-w-0 flex-wrap items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="app-eyebrow">Release</p>
          <div class="mt-1 flex min-w-0 flex-wrap items-center gap-2">
            <strong class="text-sm font-semibold text-foreground"><%= skill_definition.versioned_key %></strong>
            <% if skill_definition.latest_version? %>
              <span class="linear-count">latest</span>
            <% end %>
          </div>
        </div>
        <div class="flex shrink-0 flex-wrap justify-end gap-2">
          <% (@release_versions || {}).each do |level, version| %>
            <%= button_tag type: "submit",
                  name: "level",
                  value: level,
                  class: "app-btn app-btn-muted",
                  data: { turbo_confirm: "Release #{skill_definition.key}@#{version}?" } do %>
              <span><%= level.titleize %></span>
              <span class="linear-count">@<%= version %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <%= form.submit class: "app-btn app-btn-primary" %>
  <% end %>
<% end %>
