<% content_for :page_title, "Pipelines" %>

<section class="ops-section catalog-index catalog-list-section">
  <div class="catalog-list-head">
    <div class="min-w-0">
      <div class="flex min-w-0 items-center gap-2">
        <h2 class="linear-title">Pipeline library</h2>
        <span class="linear-count"><%= @pagination.total_count %></span>
      </div>
      <p class="mt-1 max-w-3xl truncate text-xs text-muted-foreground">Reusable action wrappers with context, triggers, snapshots, approvals, and Change Request boundaries.</p>
    </div>
    <% if permitted?(:manage_pipelines) %>
      <div class="flex items-center gap-1.5">
        <%= link_to import_pipelines_path, class: "app-icon-btn", title: "Import pipeline", aria: { label: "Import pipeline" }, data: side_panel_data do %>
          <%= lucide_icon("upload", class_name: "app-icon") %>
        <% end %>
        <%= link_to new_pipeline_path, class: "app-icon-btn", title: "New pipeline", aria: { label: "New pipeline" }, data: side_panel_data do %>
          <%= lucide_icon("plus", class_name: "app-icon") %>
        <% end %>
      </div>
    <% else %>
      <span class="app-eyebrow">Reusable action wrappers</span>
    <% end %>
  </div>

  <%= form_with url: pipelines_path, method: :get, class: "catalog-filter-bar" do %>
    <%= hidden_field_tag :mode, "list" %>
    <label class="catalog-filter-field catalog-filter-search">
      <%= lucide_icon("search", class_name: "app-icon") %>
      <%= search_field_tag :q, @query, placeholder: "Filter pipelines...", class: "catalog-filter-input" %>
    </label>
    <label class="catalog-filter-field">
      <span>Source</span>
      <%= select_tag :source,
            options_for_select([ [ "All", "" ], [ "Built-in", "built_in" ], [ "Workspace", "workspace" ] ], @source),
            class: "catalog-filter-select" %>
    </label>
    <label class="catalog-filter-field">
      <span>Trigger</span>
      <%= select_tag :trigger,
            options_for_select([ [ "All", "" ] ] + @trigger_options.map { |trigger| [ trigger.to_s.tr("_", " ").titleize, trigger ] }, @trigger),
            class: "catalog-filter-select" %>
    </label>
    <label class="catalog-filter-field">
      <span>Rows</span>
      <%= select_tag :per_page, options_for_select(AuthenticatedController::CATALOG_PER_PAGE_OPTIONS, @pagination.per_page), class: "catalog-filter-select" %>
    </label>
    <button class="app-btn app-btn-muted" type="submit">
      <%= lucide_icon("list-filter", class_name: "app-icon") %>
      <span>Apply</span>
    </button>
    <% if @query.present? || @source.present? || @trigger.present? || @pagination.per_page != AuthenticatedController::CATALOG_PER_PAGE_OPTIONS.first %>
      <%= link_to pipelines_path(mode: "list"), class: "app-btn app-btn-muted" do %>
        <%= lucide_icon("x", class_name: "app-icon") %>
        <span>Clear</span>
      <% end %>
    <% end %>
  <% end %>

  <% if @pipelines.any? %>
    <div class="catalog-table-wrap">
      <table class="app-table catalog-table">
        <colgroup>
          <col class="catalog-col-name">
          <col class="catalog-col-source">
          <col class="catalog-col-trigger">
          <col class="catalog-col-compact">
          <col class="catalog-col-wide">
          <col class="catalog-col-wide">
          <col class="catalog-col-actions">
        </colgroup>
        <thead>
          <tr>
            <th>Pipeline</th>
            <th>Source</th>
            <th>Trigger</th>
            <th>Graph</th>
            <th>Context</th>
            <th>Permissions</th>
            <th aria-label="Actions"></th>
          </tr>
        </thead>
        <tbody>
          <% @pipelines.each do |pipeline| %>
            <% nodes = pipeline.graph.fetch("nodes", []) %>
            <% edges = pipeline.graph.fetch("edges", []) %>
            <tr>
              <td>
                <%= link_to pipeline_path(pipeline), class: "catalog-table-primary" do %>
                  <span class="app-view-icon"><%= lucide_icon("workflow", class_name: "app-icon") %></span>
                  <span class="min-w-0">
                    <span><%= pipeline.name %></span>
                    <small><%= pipeline.versioned_key %></small>
                  </span>
                <% end %>
              </td>
              <td><span class="status-pill"><%= pipeline.builtin? ? "Built-in" : "Workspace" %></span></td>
              <td><span class="catalog-table-muted">@<%= pipeline.version %> · <%= pipeline.triggers.presence&.join(", ") || "manual" %></span></td>
              <td>
                <span class="catalog-table-muted"><%= pluralize(nodes.size, "step") %> · <%= pluralize(edges.size, "edge") %></span>
              </td>
              <td>
                <span class="catalog-table-muted"><%= pipeline.required_context.keys.presence&.join(", ") || "no required context" %></span>
              </td>
              <td>
                <span class="catalog-table-muted"><%= pipeline.permissions.presence&.join(", ") || "none" %></span>
              </td>
              <td>
                <div class="catalog-table-actions">
                  <%= link_to source_pipeline_path(pipeline), class: "app-icon-btn", title: "Source", aria: { label: "Source" }, data: side_panel_data do %>
                    <%= lucide_icon("file-pen-line", class_name: "app-icon") %>
                  <% end %>
                  <% if permitted?(:manage_pipelines) %>
                    <%= link_to edit_pipeline_path(pipeline), class: "app-icon-btn", title: "Edit graph", aria: { label: "Edit graph" }, data: side_panel_data do %>
                      <%= lucide_icon("workflow", class_name: "app-icon") %>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="linear-empty">
      <p>No pipelines are defined for this workspace.</p>
      <% if permitted?(:manage_pipelines) %>
        <%= link_to new_pipeline_path, class: "app-btn app-btn-muted mt-4", data: side_panel_data do %>
          <%= lucide_icon("plus", class_name: "app-icon") %>
          <span>Add pipeline</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/table_pagination",
        pagination: @pagination,
        filter_params: { mode: params[:mode].presence, q: @query, source: @source, trigger: @trigger, per_page: @pagination.per_page } %>
</section>
