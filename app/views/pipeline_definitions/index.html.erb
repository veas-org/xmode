<% content_for :page_title, "Pipelines" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Pipeline catalog</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Reusable wrappers around actions. Pipelines define the sequence, required context, triggers, permissions, snapshots, approvals, and Change Request boundaries.</p>
  </div>
</div>

<section class="linear-surface">
  <div class="linear-toolbar">
    <div class="flex min-w-0 items-center gap-2">
      <%= lucide_icon("workflow", class_name: "app-icon text-muted-foreground") %>
      <h2 class="linear-title">Pipeline library</h2>
      <span class="linear-count"><%= @pipelines.size %></span>
    </div>
    <% if permitted?(:manage_pipelines) %>
      <div class="flex items-center gap-1.5">
        <%= link_to import_pipelines_path, class: "app-icon-btn", title: "Import pipeline", aria: { label: "Import pipeline" }, data: side_panel_data do %>
          <%= lucide_icon("upload", class_name: "app-icon") %>
        <% end %>
        <%= link_to new_pipeline_path, class: "app-icon-btn", title: "New pipeline", aria: { label: "New pipeline" }, data: side_panel_data do %>
          <%= lucide_icon("plus", class_name: "app-icon") %>
        <% end %>
      </div>
    <% else %>
      <span class="app-eyebrow">Reusable action wrappers</span>
    <% end %>
  </div>

  <div class="grid gap-2 p-2 lg:grid-cols-2">
    <% @pipelines.each do |pipeline| %>
      <% nodes = pipeline.graph.fetch("nodes", []) %>
      <%= link_to pipeline_path(pipeline), class: "rounded-lg bg-muted/30 p-4 transition-colors hover:bg-muted/55" do %>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="app-eyebrow"><%= pipeline.key %></p>
            <h3 class="mt-1 truncate text-sm font-semibold text-foreground"><%= pipeline.name %></h3>
          </div>
          <span class="status-pill"><%= pluralize(nodes.size, "action") %></span>
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <% nodes.first(6).each_with_index do |node, index| %>
            <span class="status-pill"><%= index + 1 %>. <%= node["label"] || node["action_key"] %></span>
          <% end %>
          <% if nodes.size > 6 %>
            <span class="status-pill">+<%= nodes.size - 6 %></span>
          <% end %>
        </div>
        <div class="mt-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
          <span><%= pipeline.triggers.presence&.join(", ") || "manual" %></span>
          <span><%= pipeline.required_context.keys.presence&.join(", ") || "no required context" %></span>
        </div>
      <% end %>
    <% end %>
    <% if @pipelines.empty? %>
      <div class="linear-empty lg:col-span-2">
        <p>No pipelines are defined for this workspace.</p>
        <% if permitted?(:manage_pipelines) %>
          <%= link_to new_pipeline_path, class: "app-btn app-btn-muted mt-4", data: side_panel_data do %>
            <%= lucide_icon("plus", class_name: "app-icon") %>
            <span>Add pipeline</span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
