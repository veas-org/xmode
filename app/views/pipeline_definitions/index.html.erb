<% content_for :page_title, "Pipelines" %>
<div class="mb-5 flex justify-between">
  <%= form_with url: import_pipelines_path, method: :post, class: "flex flex-1 gap-2" do %>
    <%= text_area_tag :catalog_yaml, nil, rows: 1, placeholder: "Paste pipeline YAML", class: "app-input max-w-lg" %>
    <%= submit_tag "Import", class: "app-btn app-btn-muted" %>
  <% end %>
  <%= link_to "New pipeline", new_pipeline_path, class: "app-btn app-btn-primary" %>
</div>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  <% @pipelines.each do |pipeline| %>
    <%= link_to pipeline_path(pipeline), class: "app-card block p-5 hover:border-sky-400/40" do %>
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-white"><%= pipeline.name %></h2>
        <span class="status-pill"><%= pipeline.graph.fetch("nodes", []).size %> actions</span>
      </div>
      <p class="mt-3 text-sm text-zinc-400"><%= pipeline.key %></p>
    <% end %>
  <% end %>
</div>
