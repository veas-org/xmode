<% content_for :page_title, "Pipelines" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Pipeline catalog</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Reusable wrappers around actions. Pipelines define the sequence, required context, triggers, permissions, snapshots, approvals, and Change Request boundaries.</p>
  </div>
  <div class="flex flex-wrap items-center gap-2">
    <details class="app-disclosure">
      <summary>Import YAML</summary>
      <%= form_with url: import_pipelines_path, method: :post, class: "mt-3 flex min-w-0 flex-wrap gap-2" do %>
        <%= text_area_tag :catalog_yaml, nil, rows: 2, placeholder: "Paste pipeline YAML", class: "app-textarea w-64 max-w-full" %>
        <%= submit_tag "Import", class: "app-btn app-btn-muted" %>
      <% end %>
    </details>
    <%= link_to new_pipeline_path, class: "app-btn app-btn-primary" do %>
      <%= lucide_icon("plus", class_name: "app-icon") %>
      <span>Pipeline</span>
    <% end %>
  </div>
</div>

<div class="grid gap-5 lg:grid-cols-2">
  <% @pipelines.each do |pipeline| %>
    <% nodes = pipeline.graph.fetch("nodes", []) %>
    <%= link_to pipeline_path(pipeline), class: "linear-surface block p-5 transition-colors hover:bg-muted/50" do %>
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="app-eyebrow"><%= pipeline.key %></p>
          <h2 class="mt-1 truncate font-semibold text-foreground"><%= pipeline.name %></h2>
        </div>
        <span class="status-pill"><%= pluralize(nodes.size, "action") %></span>
      </div>
      <div class="mt-5 flex flex-wrap items-center gap-2">
        <% nodes.first(6).each_with_index do |node, index| %>
          <span class="status-pill"><%= index + 1 %>. <%= node["label"] || node["action_key"] %></span>
        <% end %>
        <% if nodes.size > 6 %>
          <span class="status-pill">+<%= nodes.size - 6 %></span>
        <% end %>
      </div>
      <div class="mt-5 flex flex-wrap gap-2 text-xs text-muted-foreground">
        <span><%= pipeline.triggers.presence&.join(", ") || "manual" %></span>
        <span><%= pipeline.required_context.keys.presence&.join(", ") || "no required context" %></span>
      </div>
    <% end %>
  <% end %>
</div>
