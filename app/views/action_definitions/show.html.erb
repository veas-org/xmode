<% content_for :page_title, @action.name %>
<div class="app-page-actions">
  <div class="min-w-0">
    <p class="app-eyebrow"><%= @action.key %> · <%= @action.category %> · <%= @action.provider.to_s.tr("_", " ").titleize %></p>
    <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">
      Action contract for one reusable automation skill. Pipelines use this definition to pass objective, plan, inputs, outputs, and evidence between steps.
    </p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to edit_action_path(@action), class: "app-btn app-btn-muted", data: side_panel_data do %>
      <%= lucide_icon("pencil", class_name: "app-icon") %>
      <span>Edit</span>
    <% end %>
    <%= link_to export_action_path(@action), class: "app-btn app-btn-muted" do %>
      <%= lucide_icon("download", class_name: "app-icon") %>
      <span>YAML</span>
    <% end %>
  </div>
</div>

<div class="app-detail-grid">
  <div class="space-y-5">
    <section class="linear-surface p-5">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="app-eyebrow">Action contract</p>
          <h2 class="mt-1 font-semibold text-foreground"><%= @action.name %></h2>
        </div>
        <span class="status-pill"><%= @action.builtin? ? "Built-in" : "Workspace" %></span>
      </div>

      <dl class="mt-4 grid gap-2 text-sm md:grid-cols-2">
        <div class="inbox-property"><dt>Skill</dt><dd><strong><%= @action.skill_definition&.name || "-" %></strong></dd></div>
        <div class="inbox-property"><dt>Provider</dt><dd><strong><%= @action.provider.to_s.tr("_", " ").titleize %></strong></dd></div>
        <div class="inbox-property"><dt>Objective</dt><dd><strong><%= @action.requires_objective? ? "Required" : "Optional" %></strong></dd></div>
        <div class="inbox-property"><dt>Plan fallback</dt><dd><strong><%= @action.plan_required_when_objective_unclear? ? "When unclear" : "Disabled" %></strong></dd></div>
      </dl>

      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <div>
          <p class="app-eyebrow">Objective template</p>
          <div class="rich-markdown mt-2">
            <%= render_markdown(@action.objective_template, empty: "No objective template.") %>
          </div>
        </div>
        <div>
          <p class="app-eyebrow">Plan template</p>
          <div class="rich-markdown mt-2">
            <%= render_markdown(@action.plan_template.presence || @action.skill_definition&.plan_template, empty: "No plan template.") %>
          </div>
        </div>
      </div>

      <% if @action.execution_guidance.present? %>
        <div class="mt-5">
          <p class="app-eyebrow">Execution guidance</p>
          <div class="rich-markdown mt-2">
            <%= render_markdown(@action.execution_guidance) %>
          </div>
        </div>
      <% end %>
    </section>

    <% if @action.best_practices.present? %>
      <section class="linear-surface p-5">
        <div class="flex items-center gap-2">
          <%= lucide_icon("check-circle", class_name: "app-icon text-muted-foreground") %>
          <h2 class="font-semibold text-foreground">Best practices</h2>
        </div>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <% @action.best_practices.each do |practice| %>
            <li class="app-flat-row rounded-md px-3 py-2"><%= practice %></li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </div>

  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Input contract</h3>
      <div class="mt-3 space-y-2 text-sm">
        <% @action.input_schema.fetch("properties", {}).each do |name, schema| %>
          <div class="inbox-property"><span><%= name %></span><strong><%= schema["type"] || "any" %></strong></div>
        <% end %>
        <% if @action.input_schema.fetch("properties", {}).empty? %>
          <p class="linear-empty">No named inputs.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Output contract</h3>
      <div class="mt-3 space-y-2 text-sm">
        <% @action.output_schema.fetch("properties", {}).each do |name, schema| %>
          <div class="inbox-property"><span><%= name %></span><strong><%= schema["type"] || "any" %></strong></div>
        <% end %>
        <% if @action.output_schema.fetch("properties", {}).empty? %>
          <p class="linear-empty">No named outputs.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Runtime</h3>
      <dl class="mt-3 grid gap-2 text-sm">
        <div class="inbox-property"><dt>Timeout</dt><dd><strong><%= @action.timeout_seconds %>s</strong></dd></div>
        <div class="inbox-property"><dt>Permissions</dt><dd><strong><%= @action.permissions.presence&.join(", ") || "none" %></strong></dd></div>
        <div class="inbox-property"><dt>Defaults</dt><dd><strong><%= @action.defaults.keys.presence&.join(", ") || "none" %></strong></dd></div>
        <div class="inbox-property"><dt>Artifacts</dt><dd><strong><%= @action.artifact_policy.keys.presence&.join(", ") || "default" %></strong></dd></div>
      </dl>
    </section>

    <section class="linear-surface p-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="font-medium text-foreground">Used by pipelines</h3>
        <span class="linear-count"><%= @linked_pipelines.size %></span>
      </div>
      <div class="mt-3 space-y-2">
        <% @linked_pipelines.each do |pipeline| %>
          <%= link_to pipeline_path(pipeline), class: "linear-row" do %>
            <%= lucide_icon("workflow", class_name: "app-icon text-muted-foreground") %>
            <span class="linear-row-main">
              <span class="linear-row-title"><%= pipeline.name %></span>
              <span class="linear-row-meta"><span><%= pipeline.key %></span></span>
            </span>
          <% end %>
        <% end %>
        <% if @linked_pipelines.empty? %>
          <p class="linear-empty">No pipelines use this action yet.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
