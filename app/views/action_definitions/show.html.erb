<% content_for :page_title, @action.name %>
<% skill = @action.skill_definition %>

<div class="catalog-doc-page">
  <%= render "shared/catalog_doc_tree", tree: @catalog_navigation, home_path: actions_home_path, list_path: actions_path(mode: "list"), import_path: import_actions_path, new_path: new_action_path %>

  <article class="catalog-doc-article">
    <header class="catalog-doc-hero">
      <div class="flex min-w-0 flex-wrap items-center gap-2">
        <span class="linear-count">Action</span>
        <span class="linear-count"><%= @action.versioned_key %></span>
        <span class="linear-count"><%= @action.provider.to_s.tr("_", " ").titleize %></span>
      </div>
      <h2><%= @action.name %></h2>
      <p>
        Reusable executable step for pipeline runs. This document describes the objective contract, fallback plan, provider behavior, inputs, outputs, and review evidence expected from the action.
      </p>
      <div class="catalog-doc-tags">
        <span><%= @action.category %></span>
        <span>@<%= @action.version %></span>
        <% if @action.latest_version? %>
          <span>latest</span>
        <% end %>
        <% if skill %>
          <%= link_to skill_path(skill) do %>
            <%= skill.name %> @<%= skill.version %>
          <% end %>
        <% end %>
        <span><%= @action.requires_objective? ? "objective required" : "objective optional" %></span>
        <span><%= @action.plan_required_when_objective_unclear? ? "plans unclear objectives" : "no plan fallback" %></span>
      </div>
    </header>

    <section class="catalog-doc-section">
      <p class="app-eyebrow">Action contract</p>
      <h3>How this action should be used</h3>
      <p>
        Pipelines call this action with a clear objective and, when needed, a plan. The action should keep work scoped to that contract, return structured output, and leave enough evidence for the next pipeline step or reviewer.
      </p>

      <div class="catalog-contract-grid">
        <div class="catalog-contract-item is-primary">
          <span>Version</span>
          <strong>@<%= @action.version %></strong>
          <small>Pipelines should bind to this exact action version for stable runs.</small>
        </div>
        <div class="catalog-contract-item">
          <span>Objective</span>
          <strong><%= @action.requires_objective? ? "Required" : "Optional" %></strong>
          <small>Defines the intended outcome before execution starts.</small>
        </div>
        <div class="catalog-contract-item">
          <span>Plan</span>
          <strong><%= @action.plan_required_when_objective_unclear? ? "Required when unclear" : "Optional" %></strong>
          <small>Used as a scoped fallback when the objective needs clarification.</small>
        </div>
        <div class="catalog-contract-item">
          <span>Skill</span>
          <strong><%= skill&.versioned_key || "No skill" %></strong>
          <small>Versioned instructions bound to this action.</small>
        </div>
        <div class="catalog-contract-item">
          <span>Provider</span>
          <strong><%= @action.provider.to_s.tr("_", " ").titleize %></strong>
          <small><%= @action.timeout_seconds %> second execution budget.</small>
        </div>
      </div>

      <dl class="catalog-contract-list">
        <div><dt>key</dt><dd><%= @action.key %></dd></div>
        <div><dt>version</dt><dd>@<%= @action.version %></dd></div>
        <div><dt>category</dt><dd><%= @action.category %></dd></div>
        <div><dt>definition</dt><dd><%= @action.builtin? ? "built-in" : "workspace" %></dd></div>
        <div><dt>review evidence</dt><dd><%= @action.artifact_policy.keys.presence&.join(", ") || "default" %></dd></div>
      </dl>
    </section>

    <section class="catalog-doc-section">
      <p class="app-eyebrow">Objective Template</p>
      <div class="rich-markdown catalog-doc-prose">
        <%= render_markdown(@action.objective_template, empty: "No objective template.") %>
      </div>
    </section>

    <section class="catalog-doc-section">
      <p class="app-eyebrow">Plan Template</p>
      <div class="rich-markdown catalog-doc-prose">
        <%= render_markdown(@action.plan_template.presence || skill&.plan_template, empty: "No plan template.") %>
      </div>
    </section>

    <% if @action.execution_guidance.present? %>
      <section class="catalog-doc-section">
        <p class="app-eyebrow">Execution Guidance</p>
        <div class="rich-markdown catalog-doc-prose">
          <%= render_markdown(@action.execution_guidance) %>
        </div>
      </section>
    <% end %>

    <% if @action.best_practices.present? %>
      <section class="catalog-doc-section">
        <p class="app-eyebrow">Best Practices</p>
        <ul class="catalog-doc-list">
          <% @action.best_practices.each do |practice| %>
            <li><%= practice %></li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </article>

  <aside class="catalog-doc-aside">
    <section class="catalog-doc-panel">
      <p class="app-eyebrow">Markdown definition</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <%= link_to edit_action_path(@action), class: "app-btn app-btn-muted", data: side_panel_data do %>
          <%= lucide_icon("pencil", class_name: "app-icon") %>
          <span>Edit</span>
        <% end %>
        <%= link_to source_action_path(@action), class: "app-btn app-btn-muted", data: side_panel_data do %>
          <%= lucide_icon("file-pen-line", class_name: "app-icon") %>
          <span>Source</span>
        <% end %>
        <%= link_to export_action_path(@action), class: "app-btn app-btn-muted" do %>
          <%= lucide_icon("download", class_name: "app-icon") %>
          <span>YAML</span>
        <% end %>
      </div>
    </section>

    <%= render "shared/catalog_versions", record: @action, versions: @catalog_versions %>

    <section class="catalog-doc-panel">
      <h3>Input contract</h3>
      <%= render "shared/schema_contract", schema: @action.input_schema %>
    </section>

    <section class="catalog-doc-panel">
      <h3>Output contract</h3>
      <%= render "shared/schema_contract", schema: @action.output_schema %>
    </section>

    <section class="catalog-doc-panel">
      <h3>Runtime</h3>
      <dl class="catalog-contract-list">
        <div><dt>Timeout</dt><dd><%= @action.timeout_seconds %>s</dd></div>
        <div><dt>Permissions</dt><dd><%= @action.permissions.presence&.join(", ") || "none" %></dd></div>
        <div><dt>Defaults</dt><dd><%= @action.defaults.keys.presence&.join(", ") || "none" %></dd></div>
        <div><dt>Artifacts</dt><dd><%= @action.artifact_policy.keys.presence&.join(", ") || "default" %></dd></div>
      </dl>
    </section>

    <section class="catalog-doc-panel">
      <div class="flex items-center justify-between gap-3">
        <h3>Used by pipelines</h3>
        <span class="linear-count"><%= @linked_pipelines.size %></span>
      </div>
      <div class="catalog-doc-link-list">
        <% @linked_pipelines.each do |pipeline| %>
          <%= link_to pipeline_path(pipeline) do %>
            <span><%= pipeline.name %></span>
            <small><%= pipeline.key %></small>
          <% end %>
        <% end %>
        <% if @linked_pipelines.empty? %>
          <p class="linear-empty px-0 py-3 text-left">No pipelines use this action yet.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
