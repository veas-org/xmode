<%= form_with model: action_definition, url: action_definition.persisted? ? action_path(action_definition) : actions_path, class: "space-y-4" do |form| %>
  <%= render "shared/form_errors", object: action_definition %>
  <div class="grid gap-4 sm:grid-cols-2">
    <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input", required: true %></div>
    <div><%= form.label :key, class: "app-label" %><%= form.text_field :key, class: "app-input", required: true %></div>
  </div>
  <div class="grid gap-4 sm:grid-cols-4">
    <div><%= form.label :version, class: "app-label" %><%= form.text_field :version, class: "app-input", required: true, placeholder: "1.0.0" %></div>
    <div><%= form.label :category, class: "app-label" %><%= form.select :category, ActionDefinition::CATEGORIES, {}, class: "app-input" %></div>
    <div><%= form.label :provider, class: "app-label" %><%= form.select :provider, ActionDefinition::PROVIDERS, {}, class: "app-input" %></div>
    <div><%= form.label :timeout_seconds, class: "app-label" %><%= form.number_field :timeout_seconds, class: "app-input" %></div>
  </div>
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= form.label :skill_definition_id, "Skill", class: "app-label" %>
      <%= form.collection_select :skill_definition_id, @skills || current_workspace.skill_definitions.order(:category, :name, :version), :id, :display_name, { include_blank: "No skill" }, class: "app-input" %>
    </div>
    <div>
      <%= form.label :agent_definition_id, "Agent", class: "app-label" %>
      <%= form.collection_select :agent_definition_id, @agents || current_workspace.agent_definitions.order(:category, :name, :version), :id, :display_name, { include_blank: "No agent" }, class: "app-input" %>
    </div>
  </div>
  <div class="grid gap-4 sm:grid-cols-3">
    <div class="space-y-3 pt-6 text-sm text-muted-foreground">
      <label class="flex items-center gap-2"><%= form.check_box :requires_objective %> Requires objective</label>
      <label class="flex items-center gap-2"><%= form.check_box :plan_required_when_objective_unclear %> Plan when unclear</label>
    </div>
  </div>
  <div class="grid gap-4 sm:grid-cols-2">
    <%= render "shared/markdown_editor", form: form, field: :objective_template, label: "Objective template", rows: 5 %>
    <%= render "shared/markdown_editor", form: form, field: :plan_template, label: "Plan template", rows: 5 %>
  </div>
  <%= render "shared/markdown_editor", form: form, field: :execution_guidance, label: "Execution guidance", rows: 6 %>
  <div>
    <%= label_tag "action_definition_best_practices_text", "Best practices", class: "app-label" %>
    <%= text_area_tag "action_definition[best_practices_text]", action_definition.best_practices.to_a.join("\n"), rows: 4, class: "app-textarea" %>
  </div>
  <div class="grid gap-4 sm:grid-cols-2">
    <div><%= label_tag "action_definition_input_schema_json", "Input schema JSON", class: "app-label" %><%= text_area_tag "action_definition[input_schema_json]", JSON.pretty_generate(action_definition.input_schema.presence || {}), rows: 8, class: "app-textarea font-mono text-xs" %></div>
    <div><%= label_tag "action_definition_output_schema_json", "Output schema JSON", class: "app-label" %><%= text_area_tag "action_definition[output_schema_json]", JSON.pretty_generate(action_definition.output_schema.presence || {}), rows: 8, class: "app-textarea font-mono text-xs" %></div>
  </div>
  <div><%= label_tag "action_definition_defaults_json", "Defaults JSON", class: "app-label" %><%= text_area_tag "action_definition[defaults_json]", JSON.pretty_generate(action_definition.defaults.presence || {}), rows: 5, class: "app-textarea font-mono text-xs" %></div>
  <%= form.submit class: "app-btn app-btn-primary" %>
<% end %>
