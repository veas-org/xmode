<% content_for :page_title, "Home" %>

<div class="skill-home skill-home-minimal">
  <header class="skill-home-header">
    <div class="min-w-0">
      <p class="app-eyebrow">Actions home</p>
      <h1>Actions</h1>
      <p>Executable, typed steps that bind skills to providers, objective handling, plan fallbacks, permissions, and evidence contracts.</p>
      <div class="skill-home-summary" aria-label="Action library summary">
        <span><strong><%= @stats.fetch(:actions) %></strong> actions</span>
        <span><strong><%= @stats.fetch(:categories) %></strong> categories</span>
        <span><strong><%= @stats.fetch(:providers) %></strong> providers</span>
        <span><strong><%= @stats.fetch(:skill_bound) %></strong> skill-bound</span>
      </div>
    </div>
    <div class="skill-home-actions">
      <% if permitted?(:manage_pipelines) %>
        <%= link_to new_action_path, class: "app-btn app-btn-muted", data: side_panel_data do %>
          <%= lucide_icon("plus", class_name: "app-icon") %>
          <span>New</span>
        <% end %>
        <%= link_to import_actions_path, class: "app-btn app-btn-muted", data: side_panel_data do %>
          <%= lucide_icon("upload", class_name: "app-icon") %>
          <span>Import</span>
        <% end %>
      <% end %>
    </div>
  </header>

  <div class="skill-home-spotlight-grid">
    <section class="skill-home-section">
      <div class="skill-section-title">
        <div>
          <p class="app-eyebrow">Favorites</p>
          <h2>Pinned actions</h2>
        </div>
      </div>
      <div class="skill-home-list">
        <% @favorite_actions.each do |action| %>
          <%= link_to action_path(action), class: "skill-home-row is-featured" do %>
            <span class="record-point-main">
              <span class="record-point-title"><%= action.name %></span>
              <span class="record-point-meta">
                <span><%= action.versioned_key %></span>
                <span><%= action.category %></span>
                <span><%= action.skill_definition&.versioned_key || "no skill" %></span>
              </span>
            </span>
            <span class="linear-count"><%= action.provider.to_s.tr("_", " ").titleize %></span>
          <% end %>
        <% end %>
        <% if @favorite_actions.empty? %>
          <p class="linear-empty px-0 py-4 text-left">No favorite actions are defined for this workspace.</p>
        <% end %>
      </div>
    </section>

    <section class="skill-home-section">
      <div class="skill-section-title">
        <div>
          <p class="app-eyebrow">Most used</p>
          <h2>High-traffic actions</h2>
        </div>
      </div>
      <div class="skill-home-list">
        <% @high_leverage_actions.each do |action| %>
          <%= link_to action_path(action), class: "skill-home-row" do %>
            <span class="record-point-main">
              <span class="record-point-title"><%= action.name %></span>
              <span class="record-point-meta">
                <span><%= action.versioned_key %></span>
                <span><%= action.provider.to_s.tr("_", " ").titleize %></span>
                <span><%= action.skill_definition&.name || "No skill" %></span>
              </span>
            </span>
            <span class="linear-count"><%= action_home_usage(action) %></span>
          <% end %>
        <% end %>
        <% if @high_leverage_actions.empty? %>
          <p class="linear-empty px-0 py-4 text-left">No action usage is available yet.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="skill-home-section skill-home-table-section">
    <div class="skill-section-title">
      <div>
        <p class="app-eyebrow">Library</p>
        <h2>All actions</h2>
      </div>
      <span class="linear-count"><%= @pagination.total_count %></span>
    </div>

    <%= form_with url: actions_home_path, method: :get, class: "catalog-home-filter" do %>
      <label class="catalog-filter-field catalog-filter-search">
        <%= lucide_icon("search", class_name: "app-icon") %>
        <%= search_field_tag :q, @query, placeholder: "Filter actions...", class: "catalog-filter-input" %>
      </label>
      <label class="catalog-filter-field">
        <span>Category</span>
        <%= select_tag :category,
              options_for_select([ [ "All", "" ] ] + @category_options.map { |category| [ category.to_s.titleize, category ] }, @category),
              class: "catalog-filter-select" %>
      </label>
      <label class="catalog-filter-field">
        <span>Provider</span>
        <%= select_tag :provider,
              options_for_select([ [ "All", "" ] ] + @provider_options.map { |provider| [ provider.to_s.tr("_", " ").titleize, provider ] }, @provider),
              class: "catalog-filter-select" %>
      </label>
      <label class="catalog-filter-field">
        <span>Rows</span>
        <%= select_tag :per_page, options_for_select(AuthenticatedController::CATALOG_PER_PAGE_OPTIONS, @pagination.per_page), class: "catalog-filter-select" %>
      </label>
      <button class="app-btn app-btn-muted" type="submit">
        <span>Apply</span>
      </button>
      <% if @query.present? || @category.present? || @provider.present? || @pagination.per_page != AuthenticatedController::CATALOG_PER_PAGE_OPTIONS.first %>
        <%= link_to "Clear", actions_home_path, class: "app-btn app-btn-muted" %>
      <% end %>
    <% end %>

    <% if @table_actions.any? %>
      <div class="catalog-table-wrap skill-home-table-wrap">
        <table class="app-table catalog-table skill-home-table">
          <colgroup>
            <col class="catalog-col-name">
            <col class="catalog-col-source">
            <col class="catalog-col-wide">
            <col class="catalog-col-trigger">
            <col class="catalog-col-wide">
          </colgroup>
          <thead>
            <tr>
              <th>Action</th>
              <th>Category</th>
              <th>Skill</th>
              <th>Provider</th>
              <th>Contract</th>
            </tr>
          </thead>
          <tbody>
            <% @table_actions.each do |action| %>
              <tr>
                <td>
                  <%= link_to action_path(action), class: "catalog-table-primary" do %>
                    <span class="min-w-0">
                      <span><%= action.name %></span>
                      <small><%= action.versioned_key %></small>
                    </span>
                  <% end %>
                </td>
                <td><span class="catalog-table-muted"><%= action.category.to_s.titleize %></span></td>
                <td>
                  <% if action.skill_definition %>
                    <%= link_to action.skill_definition.display_name, skill_path(action.skill_definition), class: "catalog-table-link" %>
                  <% else %>
                    <span class="catalog-table-muted">No skill</span>
                  <% end %>
                </td>
                <td><span class="catalog-table-muted"><%= action.provider.to_s.tr("_", " ").titleize %></span></td>
                <td>
                  <span class="catalog-table-muted">
                    @<%= action.version %>
                    ·
                    <%= action.requires_objective? ? "objective required" : "objective optional" %>
                    ·
                    <%= action.plan_required_when_objective_unclear? ? "plan fallback" : "plan optional" %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="linear-empty px-0 py-6 text-left">No actions match this filter.</p>
    <% end %>

    <%= render "shared/table_pagination",
          pagination: @pagination,
          filter_params: { q: @query, category: @category, provider: @provider, per_page: @pagination.per_page } %>
  </section>
</div>
