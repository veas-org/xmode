<% content_for :page_title, "New workspace" %>
<div class="mx-auto max-w-lg app-card p-6">
  <%= form_with model: @workspace, class: "space-y-4" do |form| %>
    <%= render "shared/form_errors", object: @workspace %>
    <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input", required: true %></div>
    <%= form.submit "Create workspace", class: "app-btn app-btn-primary" %>
  <% end %>
</div>
