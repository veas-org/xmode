<% content_for :page_title, @saved_view.name %>

<div class="app-page-actions">
  <div class="min-w-0">
    <p class="app-eyebrow"><%= @saved_view.view_type.tr("_", " ").titleize %> view</p>
    <p class="mt-1 max-w-2xl text-sm leading-6 text-muted-foreground"><%= @view_description %></p>
  </div>
  <%= link_to views_path, class: "app-btn app-btn-muted" do %>
    <%= lucide_icon("list-filter", class_name: "app-icon") %>
    <span>Views</span>
  <% end %>
</div>

<div class="app-detail-grid">
  <section class="linear-surface">
    <div class="linear-toolbar">
      <div class="flex min-w-0 items-center gap-2">
        <%= lucide_icon(@view_row.fetch(:icon), class_name: "app-icon text-muted-foreground") %>
        <h2 class="linear-title truncate"><%= @saved_view.name %></h2>
        <span class="linear-count"><%= @view_row.fetch(:count) %></span>
      </div>
      <span class="app-eyebrow"><%= @saved_view.team&.name || current_workspace.name %></span>
    </div>

    <% case @saved_view.view_type %>
    <% when "roadmap" %>
      <div class="linear-list">
        <% @projects.each do |project| %>
          <%= link_to project_path(project), class: "linear-row" do %>
            <span class="status-pill shrink-0"><%= project.status %></span>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= project.title %></p>
              <div class="linear-row-meta">
                <span><%= project.key %></span>
                <span><%= pluralize(project.issues.size, "issue") %></span>
                <span><%= project.repository_url.presence || "No repository" %></span>
              </div>
            </div>
          <% end %>
        <% end %>
        <% if @projects.empty? %>
          <p class="linear-empty">No projects match this view.</p>
        <% end %>
      </div>
    <% when "automation_queue" %>
      <div class="linear-list">
        <% @runs.each do |run| %>
          <%= link_to pipeline_run_path(run), class: "linear-row" do %>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= run.pipeline_definition&.name || "Pipeline run" %></p>
              <div class="linear-row-meta">
                <span><%= run.trigger %></span>
                <span><%= run.issue&.identifier || run.project&.key || "Workspace" %></span>
                <span><%= time_ago_in_words(run.created_at) %> ago</span>
              </div>
            </div>
            <span class="status-pill shrink-0"><%= run.status %></span>
          <% end %>
        <% end %>
        <% if @runs.empty? %>
          <p class="linear-empty">No automation runs match this view.</p>
        <% end %>
      </div>
    <% else %>
      <%= render "issues/table", issues: @issues %>
    <% end %>
  </section>

  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">View contract</h3>
      <dl class="mt-3 grid gap-2 text-sm">
        <div class="inbox-property"><dt>Type</dt><dd><strong><%= @saved_view.view_type.tr("_", " ").titleize %></strong></dd></div>
        <div class="inbox-property"><dt>Team</dt><dd><strong><%= @saved_view.team&.name || "Workspace" %></strong></dd></div>
        <div class="inbox-property"><dt>Source</dt><dd><strong><%= @source_path %></strong></dd></div>
        <div class="inbox-property"><dt>Results</dt><dd><strong><%= @view_row.fetch(:count) %></strong></dd></div>
      </dl>
    </section>

    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">How to use it</h3>
      <p class="mt-3 text-sm leading-6 text-muted-foreground"><%= @view_description %></p>
      <p class="mt-3 text-sm leading-6 text-muted-foreground">Saved views keep repeated operating lenses separate from the Inbox, so teams can review backlog, cycle, roadmap, and automation work without losing context.</p>
    </section>
  </aside>
</div>
