<% content_for :page_title, "Codex Sessions" %>

<div class="ops-page">
  <header class="ops-hero">
    <div class="min-w-0">
      <p class="app-eyebrow">Workspace models</p>
      <h1>Codex sessions</h1>
      <p>Open a durable xmode session that runs authenticated Codex CLI on the Oracle worker, with Codex Cloud still available as an optional runtime.</p>
      <div class="ops-summary" aria-label="Codex runtime summary">
        <span><strong><%= @codex_sessions.count %></strong> recent sessions</span>
        <span><strong><%= ENV["CODEX_CLOUD_ENV_ID"].present? ? "configured" : "optional" %></strong> cloud env</span>
        <span><strong><%= CodexSession.default_runtime %></strong> default runtime</span>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Model console", qwen_admin_path, class: "app-btn app-btn-muted" %>
      <%= link_to "Settings", settings_path(anchor: "models"), class: "app-btn app-btn-muted" %>
    </div>
  </header>

  <div class="ops-layout">
    <main class="min-w-0 space-y-5">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Open session</p>
            <h2>Oracle Codex CLI session</h2>
          </div>
        </div>

        <%= form_with model: @codex_session, url: codex_sessions_path, class: "space-y-4" do |form| %>
          <div class="grid gap-4 md:grid-cols-2">
            <div><%= form.label :title, class: "app-label" %><%= form.text_field :title, class: "app-input", placeholder: "Implement issue in sandbox" %></div>
            <div>
              <%= form.label :runtime, class: "app-label" %>
              <%= form.select :runtime, CodexSession::RUNTIMES.map { |runtime| [ CodexSession.runtime_label(runtime), runtime ] }, {}, class: "app-input" %>
            </div>
            <div><%= form.label :model, class: "app-label" %><%= form.text_field :model, class: "app-input", placeholder: CodexSession.default_model("local_cli") %></div>
            <div><%= form.label :cloud_environment_id, "Cloud environment", class: "app-label" %><%= form.text_field :cloud_environment_id, class: "app-input", placeholder: "Only for Codex Cloud mode" %></div>
            <div><%= form.label :branch, class: "app-label" %><%= form.text_field :branch, class: "app-input", placeholder: "codex/session-branch" %></div>
            <div><%= form.label :working_directory, class: "app-label" %><%= form.text_field :working_directory, class: "app-input", placeholder: CodexSession.default_working_directory %></div>
            <div>
              <%= form.label :sandbox_mode, class: "app-label" %>
              <%= form.select :sandbox_mode, CodexSession::SANDBOX_MODES.map { |mode| [ mode.tr("-", " ").titleize, mode ] }, {}, class: "app-input" %>
            </div>
            <div>
              <%= form.label :approval_policy, class: "app-label" %>
              <%= form.select :approval_policy, CodexSession::APPROVAL_POLICIES.map { |policy| [ policy.tr("-", " ").titleize, policy ] }, {}, class: "app-input" %>
            </div>
          </div>

          <div class="space-y-2">
            <%= form.label :objective, class: "app-label" %>
            <%= form.text_area :objective, rows: 7, class: "app-textarea", required: true, placeholder: "Describe what Codex should do in the Oracle sandbox. Include repository, branch policy, expected evidence, and what should be reviewed." %>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="record-point-meta">Docker CLI mode runs Codex inside an isolated worker container and stores the transcript. Codex Cloud mode is available when a cloud environment id is supplied.</p>
            <%= form.submit "Open Codex session", class: "app-btn app-btn-primary" %>
          </div>
        <% end %>
      </section>
    </main>

    <aside class="ops-side">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Recent</p>
            <h2>Sessions</h2>
          </div>
        </div>
        <div class="ops-list">
          <% @codex_sessions.each do |codex_session| %>
            <%= link_to codex_session_path(codex_session), class: "ops-row" do %>
              <%= status_icon_pill(codex_session.status, title: codex_session.display_status) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= codex_session.title %></span>
                <span class="record-point-meta">
                  <span><%= codex_session.runtime_label %></span>
                  <span><%= codex_session.model %></span>
                  <span><%= time_ago_in_words(codex_session.updated_at) %> ago</span>
                </span>
              </span>
            <% end %>
          <% end %>
          <% if @codex_sessions.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No Codex sessions yet.</p>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
