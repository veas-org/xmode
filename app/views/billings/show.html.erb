<% content_for :page_title, "Billing" %>

<div class="ops-page billing-ops-page">
  <header class="ops-hero">
    <div class="min-w-0">
      <p class="app-eyebrow">Workspace commercial model</p>
      <h1><%= current_workspace.name %> billing boundary</h1>
      <p>The open-source app stays usable in community mode. Hosted SaaS adds metering, billing, managed operations, and support around the same governed automation loop.</p>
      <div class="ops-summary" aria-label="Billing summary">
        <span><strong><%= @subscription.plan.titleize %></strong> plan</span>
        <span><strong><%= @subscription.status.to_s.titleize %></strong> status</span>
        <span><strong><%= @seat_count %>/<%= @subscription.seats %></strong> seats</span>
        <span><strong><%= @run_count %></strong> automation runs</span>
        <span><strong><%= @change_request_count %></strong> Change Requests</span>
      </div>
    </div>
    <% if permitted?(:manage_billing) %>
      <div class="flex flex-wrap items-center gap-2">
        <%= button_to checkout_billing_path, class: "app-btn app-btn-muted" do %>
          <span>Start hosted plan</span>
        <% end %>
        <%= button_to portal_billing_path, class: "app-btn app-btn-muted" do %>
          <span>Billing portal</span>
        <% end %>
      </div>
    <% end %>
  </header>

  <div class="ops-layout">
    <main class="min-w-0 space-y-5">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Current plan</p>
            <h2><%= @subscription.plan.titleize %></h2>
          </div>
          <span class="linear-count"><%= current_workspace.billing_plan.titleize %> workspace</span>
        </div>
        <p class="max-w-3xl text-sm leading-6 text-muted-foreground">Plan state is recorded per workspace so self-hosted installations and future hosted SaaS accounts can share one product model without hiding the core workflow.</p>
        <dl class="mt-4 grid gap-2 text-sm md:grid-cols-3">
          <div class="record-key-value"><dt>Seats</dt><dd><strong><%= @seat_count %>/<%= @subscription.seats %></strong></dd></div>
          <div class="record-key-value"><dt>Billing admins</dt><dd><strong><%= @billing_admin_count %></strong></dd></div>
          <div class="record-key-value"><dt>Active runs</dt><dd><strong><%= @active_run_count %></strong></dd></div>
          <div class="record-key-value"><dt>Automation runs</dt><dd><strong><%= @run_count %></strong></dd></div>
          <div class="record-key-value"><dt>Change Requests</dt><dd><strong><%= @change_request_count %></strong></dd></div>
          <div class="record-key-value"><dt>Repositories</dt><dd><strong><%= @repository_count %></strong></dd></div>
        </dl>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Automation usage</p>
            <h2>Runner minutes</h2>
          </div>
          <span class="linear-count">
            <% if @usage_limit.present? %>
              <%= @subscription.automation_minutes_used %>/<%= @usage_limit %> minutes
            <% else %>
              Custom allowance
            <% end %>
          </span>
        </div>
        <p class="max-w-3xl text-sm leading-6 text-muted-foreground">Metering tracks hosted runner consumption while leaving the AGPL workflow visible and auditable.</p>
        <div class="cycle-progress mt-4" aria-label="Automation usage">
          <span style="width: <%= @usage_percent %>%"></span>
        </div>
        <dl class="mt-4 grid gap-2 text-sm md:grid-cols-3">
          <div class="record-key-value"><dt>Used</dt><dd><strong><%= @subscription.automation_minutes_used %> minutes</strong></dd></div>
          <div class="record-key-value"><dt>Allowance</dt><dd><strong><%= @usage_limit || "Custom" %></strong></dd></div>
          <div class="record-key-value"><dt>Utilization</dt><dd><strong><%= @usage_limit.present? ? "#{@usage_percent}%" : "Negotiated" %></strong></dd></div>
        </dl>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Plan policy</p>
            <h2>Open source and hosted boundary</h2>
          </div>
          <span class="linear-count"><%= @plan_rows.size %></span>
        </div>
        <div class="ops-list">
          <% @plan_rows.each do |name, description, boundary| %>
            <article class="ops-row">
              <span class="linear-count"><%= boundary %></span>
              <span class="record-point-main">
                <span class="record-point-title"><%= name %></span>
                <span class="record-point-meta"><span><%= description %></span></span>
              </span>
              <% if @subscription.plan == name.downcase %>
                <span class="linear-count">Current</span>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    </main>

    <aside class="ops-side">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Hosted readiness</p>
            <h2>Commercial setup</h2>
          </div>
        </div>
        <dl class="ops-kv-list">
          <% @readiness_rows.each do |label, value| %>
            <div><dt><%= label %></dt><dd><%= value %></dd></div>
          <% end %>
        </dl>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Commercial boundary</p>
            <h2>What remains open</h2>
          </div>
        </div>
        <div class="ops-list">
          <article class="ops-row">
            <span class="record-point-main">
              <span class="record-point-title">Open-source core</span>
              <span class="record-point-meta"><span>Issues, cycles, skills, actions, pipelines, runs, logs, artifacts, and Change Requests remain part of the AGPL product.</span></span>
            </span>
          </article>
          <article class="ops-row">
            <span class="record-point-main">
              <span class="record-point-title">Hosted SaaS</span>
              <span class="record-point-meta"><span>Billing, managed runner capacity, usage enforcement, support, and private deployment services are commercial surfaces.</span></span>
            </span>
          </article>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Billing operations</p>
            <h2>Stripe flow</h2>
          </div>
        </div>
        <p class="text-sm leading-6 text-muted-foreground">Checkout creates the hosted subscription, Stripe webhooks sync customer and subscription state, and the portal handles invoices, payment methods, and cancellation.</p>
      </section>
    </aside>
  </div>
</div>
