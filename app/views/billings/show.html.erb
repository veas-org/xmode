<% content_for :page_title, "Billing" %>

<div class="app-detail-grid">
  <section class="linear-surface p-6">
    <p class="app-eyebrow">Workspace plan</p>
    <h2 class="mt-2 text-3xl font-semibold text-foreground"><%= @subscription.plan.titleize %></h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">Billing is intentionally isolated from the open-source app core: self-hosted teams can run community mode, while hosted workspaces can attach Stripe subscriptions and usage tracking.</p>
    <dl class="mt-6 grid gap-2 text-sm md:grid-cols-3">
      <div class="inbox-property"><dt>Status</dt><dd><strong><%= @subscription.status %></strong></dd></div>
      <div class="inbox-property"><dt>Seats</dt><dd><strong><%= @subscription.seats %></strong></dd></div>
      <div class="inbox-property"><dt>Automation minutes</dt><dd><strong><%= @subscription.automation_minutes_used %></strong></dd></div>
    </dl>
  </section>
  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Commercial boundary</h3>
      <p class="mt-3 text-sm leading-6 text-muted-foreground">The AGPL app keeps the product workflow open. Hosted SaaS billing, Stripe webhooks, and metering can be enabled without changing the core project management and automation model.</p>
    </section>
  </aside>
</div>
