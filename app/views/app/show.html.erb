<% content_for :page_title, "Command Center" %>

<div class="ops-page command-center-page">
  <header class="ops-hero command-center-hero">
    <div class="min-w-0">
      <p class="app-eyebrow"><%= current_workspace&.name %></p>
      <h1>Command Center</h1>
      <p>Review decisions, follow active work, and open the next useful surface.</p>
      <div class="ops-summary" aria-label="Workspace action summary">
        <span><strong><%= @command_counts.fetch(:waiting) %></strong> waiting</span>
        <span><strong><%= @command_counts.fetch(:active) %></strong> active</span>
        <span><strong><%= @command_counts.fetch(:failed) %></strong> failed</span>
        <span><strong><%= @command_counts.fetch(:change_requests) %></strong> Change Requests</span>
      </div>
    </div>
    <div class="skill-home-actions">
      <%= link_to automations_path, class: "app-btn app-btn-primary" do %>
        <%= lucide_icon("workflow", class_name: "app-icon") %>
        <span>Open automation</span>
      <% end %>
      <%= link_to new_issue_path, class: "app-btn app-btn-muted", data: side_panel_data do %>
        <%= lucide_icon("plus", class_name: "app-icon") %>
        <span>Issue</span>
      <% end %>
    </div>
  </header>

  <div class="ops-layout">
    <main class="min-w-0 space-y-5">
      <section class="ops-section command-attention-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Needs attention</p>
            <h2><%= @attention_runs.any? ? "Review next" : "Clear right now" %></h2>
          </div>
          <%= link_to "Queue", automations_path, class: "app-link text-xs" %>
        </div>
        <div class="ops-list">
          <% @attention_runs.each do |run| %>
            <% run_target = run.issue&.identifier || run.project&.title || run.event&.title || "Workspace" %>
            <%= link_to pipeline_run_path(run), class: "ops-row" do %>
              <%= status_icon_pill(run.status, title: run.display_status) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= run.pipeline_definition&.name || "Pipeline run" %></span>
                <span class="record-point-meta">
                  <span><%= run.display_status %></span>
                  <span><%= run_target %></span>
                  <span><%= time_ago_in_words(run.created_at) %> ago</span>
                </span>
                <% if run.input_context["objective"].present? %>
                  <span class="pipeline-run-home-objective"><%= run.input_context["objective"] %></span>
                <% end %>
              </span>
            <% end %>
          <% end %>
          <% if @attention_runs.empty? %>
            <p class="linear-empty px-0 py-4 text-left">No approvals, failed runs, or blocked automation need action.</p>
          <% end %>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Your work</p>
            <h2>Latest issues</h2>
          </div>
          <div class="workspace-pill-tabs">
            <%= link_to issues_path(view: "inbox"), class: "workspace-pill-tab" do %>
              <span>Inbox</span>
            <% end %>
            <%= link_to issues_path(view: "my"), class: "workspace-pill-tab is-active" do %>
              <span>My Issues</span>
            <% end %>
            <%= link_to issues_path(view: "backlog"), class: "workspace-pill-tab" do %>
              <span>Backlog</span>
            <% end %>
          </div>
        </div>
        <%= render "issues/list",
              issues: @issues,
              list_class: "record-detail-list",
              row_class: "record-detail-row",
              show_project: true,
              show_counts: true,
              empty_message: "No issues yet." %>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Automation</p>
            <h2>Recent runs</h2>
          </div>
          <%= link_to "All automation", automations_path, class: "app-link text-xs" %>
        </div>
        <div class="ops-list">
          <% @runs.first(6).each do |run| %>
            <%= link_to pipeline_run_path(run), class: "ops-row" do %>
              <%= status_icon_pill(run.status, title: run.display_status) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= run.pipeline_definition&.name || "Pipeline run" %></span>
                <span class="record-point-meta">
                  <span><%= run.display_trigger %></span>
                  <span><%= time_ago_in_words(run.created_at) %> ago</span>
                  <span><%= pluralize(run.run_artifacts.size, "artifact") %></span>
                </span>
              </span>
              <% if run.change_request %>
                <span class="ops-row-trailing">
                  <%= status_icon_pill(run.change_request.status, title: "#{run.change_request.status.to_s.titleize} Change Request") %>
                  <span class="linear-count">CR</span>
                </span>
              <% end %>
            <% end %>
          <% end %>
          <% if @runs.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No runs yet.</p>
          <% end %>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Projects</p>
            <h2>Active delivery tracks</h2>
          </div>
          <span class="linear-count"><%= @projects.size %></span>
        </div>
        <div class="ops-list">
          <% @projects.each do |project| %>
            <%= link_to project_path(project), class: "ops-row" do %>
              <%= status_icon_pill(project.status, title: project.status.to_s.titleize) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= project.title %></span>
                <span class="record-point-meta">
                  <span><%= project.key %></span>
                  <span><%= pluralize(project.issues.size, "issue") %></span>
                  <span><%= project.team.name %></span>
                </span>
              </span>
            <% end %>
          <% end %>
          <% if @projects.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No projects yet.</p>
          <% end %>
        </div>
      </section>
    </main>

    <aside class="ops-side">
      <% if current_workspace.demo? && @demo_agent_pipeline %>
        <section class="ops-section home-demo-panel">
          <div class="ops-section-head">
            <div>
              <p class="app-eyebrow">Planet Express demo</p>
              <h2>Run the core loop</h2>
            </div>
          </div>
          <%= form_with url: run_pipeline_path(@demo_agent_pipeline), method: :post, class: "space-y-4" do %>
            <div class="home-pipeline-brief" aria-label="Demo pipeline steps">
              <% [ "Plan", "Approve", "Code", "Test", "Change Request" ].each do |step| %>
                <span><%= step %></span>
              <% end %>
            </div>
            <div>
              <%= label_tag "input_context_objective", "Objective", class: "app-label" %>
              <%= text_field_tag "input_context[objective]",
                    @demo_agent_objective,
                    id: "input_context_objective",
                    class: "app-input",
                    required: true %>
            </div>
            <div>
              <%= label_tag :project_id, "Project", class: "app-label" %>
              <%= select_tag :project_id,
                    options_from_collection_for_select(@demo_agent_projects || [], :id, :title, (@demo_agent_projects || []).first&.id),
                    class: "app-input" %>
            </div>
            <%= submit_tag "Run demo agent", class: "app-btn app-btn-primary w-full" %>
          <% end %>
        </section>
      <% end %>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Change Requests</p>
            <h2>Latest review output</h2>
          </div>
          <%= link_to "All", change_requests_path, class: "app-link text-xs" %>
        </div>
        <div class="ops-list">
          <% @recent_change_requests.each do |change_request| %>
            <%= link_to change_request_path(change_request), class: "ops-row" do %>
              <%= status_icon_pill(change_request.status, title: change_request.status.to_s.titleize) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= change_request.title %></span>
                <span class="record-point-meta">
                  <span><%= change_request.provider %></span>
                  <span><%= change_request.issue&.identifier || "No issue" %></span>
                </span>
              </span>
            <% end %>
          <% end %>
          <% if @recent_change_requests.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No Change Requests yet.</p>
          <% end %>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Event inbox</p>
            <h2>Latest events</h2>
          </div>
          <%= link_to "Triggers", automations_path(tab: "triggers"), class: "app-link text-xs" %>
        </div>
        <div class="ops-list">
          <% @events.each do |event| %>
            <%= link_to event_path(event), class: "ops-row" do %>
              <%= status_icon_pill(event.severity, title: "#{event.severity.titleize} severity") %>
              <span class="record-point-main">
                <span class="record-point-title"><%= event.title %></span>
                <span class="record-point-meta"><span><%= event.source %></span></span>
              </span>
              <%= status_icon_pill(event.status, title: "#{event.status.titleize} status") %>
            <% end %>
          <% end %>
          <% if @events.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No events yet.</p>
          <% end %>
        </div>
      </section>

      <section class="ops-section command-model-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">How it works</p>
            <h2>Governed loop</h2>
          </div>
        </div>
        <div class="command-loop-compact">
          <% [ "Objective", "Plan", "Action", "Run", "Change Request" ].each_with_index do |title, index| %>
            <span><strong><%= index + 1 %></strong><%= title %></span>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
