<% content_for :page_title, "Command Center" %>

<div class="ops-page command-center-page">
  <header class="ops-hero">
    <div class="min-w-0">
      <p class="app-eyebrow"><%= current_workspace&.name %> operating model</p>
      <h1>One governed loop from objective to Change Request</h1>
      <p>Every automation run should make the intended outcome, approved plan, execution evidence, and review package visible to the team.</p>
      <div class="ops-summary" aria-label="Operating model summary">
        <span><strong><%= @operating_counts.fetch(:objectives) %></strong> objectives</span>
        <span><strong><%= @operating_counts.fetch(:plans) %></strong> plans</span>
        <span><strong><%= @operating_counts.fetch(:skills) %></strong> skills</span>
        <span><strong><%= @operating_counts.fetch(:actions) %></strong> actions</span>
        <span><strong><%= @operating_counts.fetch(:runs) %></strong> runs</span>
        <span><strong><%= @operating_counts.fetch(:change_requests) %></strong> Change Requests</span>
      </div>
    </div>
  </header>

  <div class="ops-layout">
    <main class="min-w-0 space-y-5">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Operating model</p>
            <h2>Governed automation loop</h2>
          </div>
        </div>
        <div class="command-loop-grid">
          <% [
            [ "Objective", "#{@operating_counts.fetch(:objectives)} active", "Defines the outcome before any agent work starts." ],
            [ "Plan", "#{@operating_counts.fetch(:plans)} records", "Names scope, risks, checks, and approval points." ],
            [ "Skill + Action", "#{@operating_counts.fetch(:skills)} skills", "Turns reusable team capability into executable steps." ],
            [ "Run", "#{@operating_counts.fetch(:runs)} runs", "Captures logs, artifacts, approvals, and structured output." ],
            [ "Change Request", "#{@operating_counts.fetch(:change_requests)} open", "Packages code-changing work on a branch for review." ]
          ].each_with_index do |(title, count, body), index| %>
            <article class="command-loop-step">
              <span class="linear-count"><%= index + 1 %></span>
              <h3><%= title %></h3>
              <p><%= body %></p>
              <strong><%= count %></strong>
            </article>
          <% end %>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Your work</p>
            <h2>Latest issues</h2>
          </div>
          <div class="workspace-pill-tabs">
            <%= link_to issues_path(view: "inbox"), class: "workspace-pill-tab" do %>
              <span>Inbox</span>
            <% end %>
            <%= link_to issues_path(view: "my"), class: "workspace-pill-tab is-active" do %>
              <span>My Issues</span>
            <% end %>
            <%= link_to issues_path(view: "backlog"), class: "workspace-pill-tab" do %>
              <span>Backlog</span>
            <% end %>
          </div>
        </div>
        <%= render "issues/list",
              issues: @issues,
              list_class: "record-detail-list",
              row_class: "record-detail-row",
              show_project: true,
              show_counts: true,
              empty_message: "No issues yet." %>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Projects</p>
            <h2>Active delivery tracks</h2>
          </div>
          <span class="linear-count"><%= @projects.size %></span>
        </div>
        <div class="ops-list">
          <% @projects.each do |project| %>
            <%= link_to project_path(project), class: "ops-row" do %>
              <%= status_icon_pill(project.status, title: project.status.to_s.titleize) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= project.title %></span>
                <span class="record-point-meta">
                  <span><%= project.key %></span>
                  <span><%= pluralize(project.issues.size, "issue") %></span>
                  <span><%= project.team.name %></span>
                </span>
              </span>
            <% end %>
          <% end %>
          <% if @projects.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No projects yet.</p>
          <% end %>
        </div>
      </section>
    </main>

    <aside class="ops-side">
      <section class="ops-section home-decision-panel">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Next decision</p>
            <h2><%= @approval_run ? (@approval_run.pipeline_definition&.name || "Pipeline run") : "No pending approvals" %></h2>
          </div>
        </div>
        <% if @approval_run %>
          <p class="text-sm leading-6 text-muted-foreground"><%= @approval_run.issue&.title || @approval_run.input_context["objective"] || "Review the pending automation decision." %></p>
          <div class="mt-3 flex min-w-0 flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-2">
              <%= status_icon_pill(@approval_run.status, title: "Waiting for approval") %>
              <span class="text-sm text-muted-foreground">Approval</span>
            </span>
            <span class="linear-count"><%= time_ago_in_words(@approval_run.created_at) %> ago</span>
          </div>
          <%= link_to pipeline_run_path(@approval_run), class: "app-btn app-btn-primary mt-4 w-full" do %>
            <span>Review run</span>
          <% end %>
        <% else %>
          <p class="text-sm leading-6 text-muted-foreground">Create or run a pipeline when the team has a clear objective ready for automation.</p>
        <% end %>
      </section>

      <% if current_workspace.demo? && @demo_agent_pipeline %>
        <section class="ops-section home-demo-panel">
          <div class="ops-section-head">
            <div>
              <p class="app-eyebrow">Planet Express demo</p>
              <h2>Governed agent scenario</h2>
            </div>
          </div>
          <%= form_with url: run_pipeline_path(@demo_agent_pipeline), method: :post, class: "space-y-4" do %>
            <p class="text-sm leading-6 text-muted-foreground">Launch a realistic Implement Issue run: objective capture, plan verification, sandboxed agent execution, test evidence, and a Change Request trail.</p>
            <div class="home-pipeline-brief" aria-label="Demo pipeline steps">
              <% [ "Plan", "Approve", "Code", "Test", "Change Request" ].each do |step| %>
                <span><%= step %></span>
              <% end %>
            </div>
            <div>
              <%= label_tag "input_context_objective", "Objective", class: "app-label" %>
              <%= text_field_tag "input_context[objective]",
                    @demo_agent_objective,
                    id: "input_context_objective",
                    class: "app-input",
                    required: true %>
            </div>
            <div>
              <%= label_tag :project_id, "Project", class: "app-label" %>
              <%= select_tag :project_id,
                    options_from_collection_for_select(@demo_agent_projects || [], :id, :title, (@demo_agent_projects || []).first&.id),
                    class: "app-input" %>
            </div>
            <%= submit_tag "Run demo agent", class: "app-btn app-btn-primary w-full" %>
          <% end %>
        </section>
      <% end %>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Automation queue</p>
            <h2>Recent runs</h2>
          </div>
          <span class="linear-count"><%= @runs.size %></span>
        </div>
        <div class="ops-list">
          <% @runs.each do |run| %>
            <%= link_to pipeline_run_path(run), class: "ops-row" do %>
              <%= status_icon_pill(run.status, title: run.display_status) %>
              <span class="record-point-main">
                <span class="record-point-title"><%= run.pipeline_definition&.name || "Pipeline run" %></span>
                <span class="record-point-meta">
                  <span><%= run.display_trigger %></span>
                  <span><%= time_ago_in_words(run.created_at) %> ago</span>
                </span>
              </span>
            <% end %>
          <% end %>
          <% if @runs.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No runs yet.</p>
          <% end %>
        </div>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Event inbox</p>
            <h2>Latest events</h2>
          </div>
          <span class="linear-count"><%= @events.size %></span>
        </div>
        <div class="ops-list">
          <% @events.each do |event| %>
            <%= link_to event_path(event), class: "ops-row" do %>
              <%= status_icon_pill(event.severity, title: "#{event.severity.titleize} severity") %>
              <span class="record-point-main">
                <span class="record-point-title"><%= event.title %></span>
                <span class="record-point-meta"><span><%= event.source %></span></span>
              </span>
              <%= status_icon_pill(event.status, title: "#{event.status.titleize} status") %>
            <% end %>
          <% end %>
          <% if @events.empty? %>
            <p class="linear-empty px-0 py-5 text-left">No events yet.</p>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
