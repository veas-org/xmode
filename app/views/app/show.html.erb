<% content_for :page_title, "Command Center" %>

<section class="operating-map">
  <div class="linear-surface p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="app-eyebrow"><%= current_workspace&.name %> operating model</p>
        <div class="mt-1 flex items-center gap-2">
          <%= lucide_icon("workflow", class_name: "app-icon text-muted-foreground") %>
          <h2 class="text-base font-semibold text-foreground">One governed loop from objective to Change Request</h2>
        </div>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">Every automation run should make the intended outcome, approved plan, execution evidence, and review package visible to the team.</p>
      </div>
    </div>
    <div class="operating-map-steps mt-4">
      <% [
        [ "circle-dot", "Objective", "#{@operating_counts.fetch(:objectives)} active", "Defines the outcome before any agent work starts." ],
        [ "list", "Plan", "#{@operating_counts.fetch(:plans)} records", "Names scope, risks, checks, and approval points." ],
        [ "sparkles", "Skill + Action", "#{@operating_counts.fetch(:skills)} skills", "Turns reusable team capability into executable steps." ],
        [ "activity", "Run", "#{@operating_counts.fetch(:runs)} runs", "Captures logs, artifacts, approvals, and structured output." ],
        [ "git-pull-request", "Change Request", "#{@operating_counts.fetch(:change_requests)} open", "Packages code-changing work on a branch for review." ]
      ].each do |icon, title, count, body| %>
        <article class="operating-map-step">
          <div class="flex items-center justify-between gap-2">
            <span class="status-icon-pill" title="<%= title %>" aria-label="<%= title %>">
              <%= lucide_icon(icon, class_name: "app-icon") %>
            </span>
            <span class="status-pill"><%= count %></span>
          </div>
          <div class="mt-3 flex items-center justify-between gap-2">
            <h3 class="text-sm font-semibold text-foreground"><%= title %></h3>
          </div>
          <p class="mt-2 text-xs leading-5 text-muted-foreground"><%= body %></p>
        </article>
      <% end %>
    </div>
  </div>
  <aside class="linear-surface p-4 home-decision-panel">
    <div class="flex items-center gap-2">
      <%= lucide_icon("hand", class_name: "app-icon text-muted-foreground") %>
      <p class="app-eyebrow">Next decision</p>
    </div>
    <% if @approval_run %>
      <h2 class="mt-2 text-sm font-semibold text-foreground"><%= @approval_run.pipeline_definition&.name || "Pipeline run" %></h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground"><%= @approval_run.issue&.title || @approval_run.input_context["objective"] || "Review the pending automation decision." %></p>
      <div class="home-decision-meta">
        <span class="inline-flex items-center gap-2">
          <%= status_icon_pill(@approval_run.status, title: "Waiting for approval") %>
          <span>Approval</span>
        </span>
        <strong><%= time_ago_in_words(@approval_run.created_at) %> ago</strong>
      </div>
      <%= link_to pipeline_run_path(@approval_run), class: "app-btn app-btn-primary mt-4 w-full" do %>
        <%= lucide_icon("eye", class_name: "app-icon") %>
        <span>Review run</span>
      <% end %>
    <% else %>
      <h2 class="mt-2 text-sm font-semibold text-foreground">No pending approvals</h2>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">Create or run a pipeline when the team has a clear objective ready for automation.</p>
    <% end %>
  </aside>
</section>

<div class="linear-page">
  <div class="space-y-4">
    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex min-w-0 items-center gap-3">
          <%= lucide_icon("inbox", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Your work</h2>
          <span class="linear-count"><%= @issues.size %></span>
        </div>
        <div class="linear-tabs">
          <%= link_to "Inbox", issues_path(view: "inbox"), class: "linear-tab" %>
          <%= link_to "My Issues", issues_path(view: "my"), class: "linear-tab is-active" %>
          <%= link_to "Backlog", issues_path(view: "backlog"), class: "linear-tab" %>
        </div>
      </div>

      <div class="linear-list">
        <% @issues.each do |issue| %>
          <%= link_to issue_path(issue), class: "linear-row" do %>
            <%= status_icon_pill(issue.display_status, title: issue.display_status) %>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= issue.identifier %> <%= issue.title %></p>
              <div class="linear-row-meta">
                <span><%= issue.project&.title || "No project" %></span>
                <span title="Priority"><%= issue.priority %></span>
                <span><%= issue.assignee&.display_name || "Unassigned" %></span>
              </div>
            </div>
            <span class="hidden text-xs text-muted-foreground sm:block"><%= time_ago_in_words(issue.updated_at) %> ago</span>
          <% end %>
        <% end %>
        <% if @issues.empty? %>
          <p class="linear-empty">No issues yet.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex items-center gap-3">
          <%= lucide_icon("folder", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Projects</h2>
          <span class="linear-count"><%= @projects.size %></span>
        </div>
      </div>

      <div class="linear-list">
        <% @projects.each do |project| %>
          <%= link_to project_path(project), class: "linear-row" do %>
            <%= status_icon_pill(project.status, title: project.status.to_s.titleize) %>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= project.title %></p>
              <div class="linear-row-meta">
                <span><%= project.key %></span>
                <span><%= pluralize(project.issues.count, "issue") %></span>
                <span><%= project.team.name %></span>
              </div>
            </div>
          <% end %>
        <% end %>
        <% if @projects.empty? %>
          <p class="linear-empty">No projects yet.</p>
        <% end %>
      </div>
    </section>
  </div>

  <aside class="linear-side">
    <% if current_workspace.demo? && @demo_agent_pipeline %>
      <section class="linear-surface home-demo-panel">
        <div class="linear-toolbar">
          <div class="min-w-0">
            <p class="app-eyebrow">Planet Express demo</p>
            <div class="mt-1 flex items-center gap-2">
              <%= lucide_icon("sparkles", class_name: "app-icon text-muted-foreground") %>
              <h2 class="linear-title">Governed agent scenario</h2>
            </div>
          </div>
        </div>
        <%= form_with url: run_pipeline_path(@demo_agent_pipeline), method: :post, class: "space-y-4 p-4" do %>
          <p class="text-sm leading-6 text-muted-foreground">Launch a realistic Implement Issue run: objective capture, plan verification, sandboxed agent execution, test evidence, and a Change Request trail.</p>
          <div class="home-pipeline-brief" aria-label="Demo pipeline steps">
            <% [
              [ "list", "Plan" ],
              [ "hand", "Approve" ],
              [ "code", "Code" ],
              [ "check-circle", "Test" ],
              [ "git-pull-request", "Change Request" ]
            ].each do |icon, step| %>
              <span class="inline-flex items-center gap-2">
                <%= lucide_icon(icon, class_name: "app-icon") %>
                <span><%= step %></span>
              </span>
            <% end %>
          </div>
          <div>
            <%= label_tag "input_context_objective", "Objective", class: "app-label" %>
            <%= text_field_tag "input_context[objective]",
                  @demo_agent_objective,
                  id: "input_context_objective",
                  class: "app-input",
                  required: true %>
          </div>
          <div>
            <%= label_tag :project_id, "Project", class: "app-label" %>
            <%= select_tag :project_id,
                  options_from_collection_for_select(@demo_agent_projects || [], :id, :title, (@demo_agent_projects || []).first&.id),
                  class: "app-input" %>
          </div>
          <%= submit_tag "Run demo agent", class: "app-btn app-btn-primary w-full" %>
        <% end %>
      </section>
    <% end %>

    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex items-center gap-3">
          <%= lucide_icon("activity", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Automation queue</h2>
          <span class="linear-count"><%= @runs.size %></span>
        </div>
      </div>

      <div class="linear-list">
        <% @runs.each do |run| %>
          <%= link_to pipeline_run_path(run), class: "linear-row" do %>
            <%= status_icon_pill(run.status, title: run.display_status) %>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= run.pipeline_definition&.name || "Pipeline run" %></p>
              <div class="linear-row-meta">
                <span><%= run.display_trigger %></span>
                <span><%= time_ago_in_words(run.created_at) %> ago</span>
              </div>
            </div>
          <% end %>
        <% end %>
        <% if @runs.empty? %>
          <p class="linear-empty">No runs yet.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex items-center gap-3">
          <%= lucide_icon("bell", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Event inbox</h2>
          <span class="linear-count"><%= @events.size %></span>
        </div>
      </div>

      <div class="linear-list">
        <% @events.each do |event| %>
          <%= link_to event_path(event), class: "linear-row" do %>
            <%= status_icon_pill(event.severity, title: "#{event.severity.titleize} severity") %>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= event.title %></p>
              <div class="linear-row-meta">
                <span><%= event.source %></span>
                <span title="<%= event.status.titleize %> status"><%= event.status %></span>
              </div>
            </div>
          <% end %>
        <% end %>
        <% if @events.empty? %>
          <p class="linear-empty">No events yet.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
