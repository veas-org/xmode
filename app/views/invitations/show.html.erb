<section class="mx-auto flex min-h-[calc(100vh-73px)] max-w-md items-center px-5 py-12">
  <div class="app-card w-full p-6">
    <p class="app-eyebrow">Workspace invitation</p>
    <h1 class="mt-2 text-2xl font-semibold text-foreground">Join <%= @invitation.workspace.name %></h1>
    <p class="mt-3 text-sm leading-6 text-muted-foreground">
      <%= @invitation.email %> has been invited as <%= @invitation.role.titleize %><%= " on #{@invitation.team.name}" if @invitation.team %>.
    </p>

    <% if @invitation.accepted? %>
      <p class="mt-5 rounded-md bg-muted/35 p-3 text-sm text-muted-foreground">This invitation has already been accepted.</p>
    <% elsif @invitation.expired? %>
      <p class="mt-5 rounded-md bg-muted/35 p-3 text-sm text-muted-foreground">This invitation has expired.</p>
    <% elsif logged_in? %>
      <%= button_to "Accept invitation", accept_invitation_path(@invitation.token), class: "app-btn app-btn-primary mt-6 w-full" %>
    <% else %>
      <div class="mt-6 grid gap-3">
        <%= link_to "Create account", signup_path(invitation_token: @invitation.token), class: "app-btn app-btn-primary w-full" %>
        <%= link_to "Sign in", login_path, class: "app-btn app-btn-muted w-full" %>
      </div>
    <% end %>
  </div>
</section>
