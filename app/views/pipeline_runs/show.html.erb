<% content_for :page_title, "Run ##{@run.id}" %>
<% run_name = @run.pipeline_definition&.name || "Pipeline run" %>
<% target_label = @run.issue&.identifier || @run.project&.title || @run.event&.title || "workspace run" %>
<% run_context = (@run.input_context || {}).to_h %>
<% objective_text = run_context["objective"].presence || @steps.map { |step| (step.input_json || {}).to_h["objective"].presence }.compact.first || @run.issue&.title || "Objective not captured yet." %>
<% structured_plan_step = @steps.find { |step| step.output_json.to_h["status"] == "planned" && step.output_json.to_h["plan"].present? } ||
  @steps.find { |step| step.action_definition&.category == "planning" && step.output_json.to_h["plan"].present? } ||
  @steps.find { |step| step.output_json.to_h["plan"].present? && step.name.to_s.match?(/plan/i) } %>
<% artifact_plan_step = structured_plan_step || @steps.find { |step| step.action_definition&.category == "planning" || step.name.to_s.match?(/plan/i) } %>
<% generated_plan_step = structured_plan_step || artifact_plan_step %>
<% generated_plan_output = generated_plan_step&.output_json.to_h %>
<% generated_plan_artifact = if generated_plan_output&.dig("plan").blank? && artifact_plan_step
  @artifacts.find { |artifact| artifact.action_run_step_id == artifact_plan_step.id && artifact.name == "stdout.log" && artifact.content_type.to_s.start_with?("text/") }
end %>
<% generated_plan_artifact_text = generated_plan_artifact ? artifact_text_preview(generated_plan_artifact, max_bytes: 32_000)&.strip : nil %>
<% generated_plan_text = renderable_plan_text(generated_plan_output&.dig("plan")).presence || generated_plan_artifact_text.presence %>
<% run_plan_text = renderable_plan_text(run_context["plan"]).presence %>
<% input_plan_text = @steps.map { |step| renderable_plan_text((step.input_json || {}).to_h["plan"]).presence }.compact.first %>
<% plan_text = run_plan_text || generated_plan_text || input_plan_text || "Plan will be captured before execution continues." %>
<% plan_source_detail = generated_plan_output["model"].presence || (generated_plan_artifact&.name if generated_plan_artifact_text.present?) %>
<% plan_source_label = generated_plan_step ? "#{generated_plan_step.name}#{plan_source_detail.present? ? " · #{plan_source_detail}" : ""}" : "Run context" %>
<% plan_acceptance_checks = Array(generated_plan_output&.dig("acceptance_checks")).select(&:present?) %>
<% plan_next_steps = Array(generated_plan_output&.dig("next_steps")).select(&:present?) %>
<% current_step = @steps.find { |step| step.status.in?(%w[running waiting_for_approval waiting_for_input]) } || @steps.last %>
<% completed_steps = @steps.count { |step| step.status == "completed" } %>
<% evidence_total = @artifacts.size + @logs.size + @sandbox_sessions.size + @approvals.size + @run_messages.size %>
<% progress_percent = @steps.any? ? ((completed_steps.to_f / @steps.size) * 100).round : 0 %>
<% changed_files = run_changed_file_entries(@steps, @change_request) %>
<% visual_artifacts = run_visual_artifacts(@artifacts) %>
<% active_codex_session = @codex_sessions.first %>
<% codex_chat_runtime = active_codex_session&.runtime || CodexSession.default_runtime %>
<% codex_chat_model = active_codex_session&.model || CodexSession.default_model(codex_chat_runtime) %>
<% decision_label = if @pending_run_message
  "Answer required"
elsif @pending_approval
  "Approval required"
elsif @run.status == "completed" && @change_request
  "Review and release"
elsif @run.status == "completed"
  "Review complete"
else
  @run.display_status
end %>
<% decision_summary = if @pending_run_message
  @pending_run_message.content.presence || "The run is paused until you answer."
elsif @pending_approval
  "#{current_step&.name || "Manual approval"} is paused until you approve, revise, or stop."
elsif @run.error_message.present?
  @run.error_message
elsif @change_request
  "A branch-backed Change Request is ready for code review."
elsif current_step&.output_json.to_h["summary"].present?
  current_step.output_json["summary"]
elsif @run.status == "completed"
  "The run finished with #{pluralize(evidence_total, "evidence item")}."
else
  current_step ? "#{current_step.name} is the current focus." : "Run is waiting for its first step."
end %>
<% stage_rows = [
  [ :plan, "Plan", "Approve scope before coding" ],
  [ :work, "Sandbox", "Code runs in isolation" ],
  [ :review, "Review", "Inspect code and visual evidence" ],
  [ :release, "Release", "Open or merge through CR" ]
] %>
<% @codex_sessions.map(&:stream_key).uniq.each do |stream_key| %>
  <%= turbo_stream_from stream_key %>
<% end %>

<div class="run-review-shell" data-controller="run-chat">
  <aside class="run-review-sidebar">
    <header class="run-review-sidebar-head">
      <div>
        <p class="app-eyebrow">Sessions</p>
        <h2>Pipeline runs</h2>
      </div>
      <%= link_to pipeline_runs_path, class: "app-icon-btn", title: "All runs", aria: { label: "All runs" } do %>
        <%= lucide_icon("list", class_name: "app-icon") %>
      <% end %>
    </header>

    <div class="run-review-session-list">
      <% @session_runs.each do |run| %>
        <% session_active = run.id == @run.id %>
        <% session_name = run.pipeline_definition&.name || "Pipeline run" %>
        <% session_target = run.issue&.identifier || run.project&.key || run.project&.title || "workspace" %>
        <%= link_to pipeline_run_path(run), class: "run-review-session-row #{session_active ? "is-active" : ""}" do %>
          <span>
            <strong>Run #<%= run.id %></strong>
            <%= status_icon_pill(run.status, title: run.display_status) %>
          </span>
          <em><%= session_name %></em>
          <small><%= session_target %> · <%= time_ago_in_words(run.updated_at) %> ago</small>
        <% end %>
      <% end %>
    </div>
  </aside>

  <main class="run-review-main">
    <header class="run-review-hero">
      <div class="run-review-kicker">
        <span>Run #<%= @run.id %></span>
        <span><%= target_label %></span>
        <span><%= @run.display_trigger %></span>
      </div>
      <div class="run-review-hero-row">
        <div class="min-w-0">
          <h1><%= run_name %></h1>
          <p><%= objective_text %></p>
        </div>
        <div class="run-review-hero-actions">
          <%= status_icon_pill(@run.status, title: @run.display_status) %>
          <% if @run.issue %>
            <%= link_to issue_path(@run.issue), class: "app-btn app-btn-muted" do %>
              <%= lucide_icon("circle-dot", class_name: "app-icon") %>
              <span><%= @run.issue.identifier %></span>
            <% end %>
          <% end %>
          <% if @change_request %>
            <%= link_to change_request_path(@change_request), class: "app-btn app-btn-primary" do %>
              <%= lucide_icon("git-pull-request", class_name: "app-icon") %>
              <span>Review changes</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </header>

    <section class="run-review-decision <%= "is-blocked" if @pending_run_message || @pending_approval %>" aria-label="Current decision">
      <div class="run-review-decision-copy">
        <p class="app-eyebrow"><%= @pending_run_message || @pending_approval ? "Stopped for you" : "Current state" %></p>
        <h2><%= decision_label %></h2>
        <p><%= decision_summary %></p>
      </div>
      <div class="run-review-decision-actions">
        <% if @pending_run_message %>
          <% if @pending_run_message.choices.any? %>
            <% @pending_run_message.choices.each do |choice| %>
              <% choice_key = choice["key"].to_s %>
              <% choice_button_class = if choice_key.match?(/approve|accept|continue|yes/)
                "app-btn app-btn-primary"
              elsif choice_key.match?(/reject|cancel|stop|no/)
                "app-btn app-btn-danger"
              else
                "app-btn app-btn-muted"
              end %>
              <%= button_to pipeline_run_run_message_path(@run, @pending_run_message),
                    method: :post,
                    params: { choice: choice["key"] },
                    class: choice_button_class do %>
                <span><%= choice["label"].presence || choice["key"].to_s.humanize %></span>
              <% end %>
            <% end %>
          <% else %>
            <%= form_with url: pipeline_run_run_message_path(@run, @pending_run_message), class: "run-review-answer-form" do |form| %>
              <%= form.text_area :content,
                    rows: 3,
                    class: "app-textarea",
                    placeholder: @pending_run_message.kind == "goal_check" ? "Add goal-check notes..." : "Reply with context...",
                    data: {
                      run_chat_target: "input",
                      action: "input->run-chat#autosize keydown->run-chat#submitOnEnter"
                    } %>
              <%= form.submit "Send", class: "app-btn app-btn-primary" %>
            <% end %>
          <% end %>
        <% elsif @pending_approval %>
          <%= button_to approve_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-primary" do %>
            <%= lucide_icon("check", class_name: "app-icon") %>
            <span>Approve</span>
          <% end %>
          <%= button_to reject_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-danger" do %>
            <%= lucide_icon("x", class_name: "app-icon") %>
            <span>Stop</span>
          <% end %>
        <% elsif @change_request %>
          <%= link_to change_request_path(@change_request), class: "app-btn app-btn-primary" do %>
            <%= lucide_icon("git-pull-request", class_name: "app-icon") %>
            <span>Review package</span>
          <% end %>
        <% elsif @can_resume %>
          <%= button_to resume_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-muted" do %>
            <%= lucide_icon("rotate-cw", class_name: "app-icon") %>
            <span>Resume</span>
          <% end %>
        <% else %>
          <span class="linear-count"><%= completed_steps %>/<%= @steps.size %> steps</span>
        <% end %>
      </div>
    </section>

    <section class="run-review-stages" aria-label="Run stages">
      <% stage_rows.each do |stage, label, description| %>
        <% stage_status = run_stage_status(@steps, stage, change_request: @change_request) %>
        <div class="run-review-stage is-<%= stage_status %>">
          <%= lucide_icon(run_stage_icon(stage_status), class_name: "app-icon") %>
          <span>
            <strong><%= label %></strong>
            <small><%= description %></small>
          </span>
        </div>
      <% end %>
    </section>

    <section class="run-review-panels" aria-label="Run review workspace">
      <article class="run-review-panel is-primary">
        <header>
          <div>
            <p class="app-eyebrow">Plan</p>
            <h2>Generated plan</h2>
          </div>
          <span class="linear-count"><%= plan_source_label %></span>
        </header>
        <div class="rich-markdown run-review-markdown">
          <%= render_markdown(plan_text, empty: "Plan will be captured before execution continues.") %>
        </div>
        <% if plan_next_steps.any? || plan_acceptance_checks.any? %>
          <div class="run-review-support-grid">
            <% if plan_next_steps.any? %>
              <section>
                <h3>Next</h3>
                <ul>
                  <% plan_next_steps.each do |item| %>
                    <li><%= item %></li>
                  <% end %>
                </ul>
              </section>
            <% end %>
            <% if plan_acceptance_checks.any? %>
              <section>
                <h3>Acceptance</h3>
                <ul>
                  <% plan_acceptance_checks.each do |check| %>
                    <li><%= check %></li>
                  <% end %>
                </ul>
              </section>
            <% end %>
          </div>
        <% end %>
      </article>

      <article class="run-review-panel">
        <header>
          <div>
            <p class="app-eyebrow">Review</p>
            <h2>Code and visual evidence</h2>
          </div>
          <span class="linear-count"><%= pluralize(changed_files.size, "file") %></span>
        </header>
        <% if changed_files.any? %>
          <div class="run-review-file-list">
            <% changed_files.first(8).each do |file| %>
              <div>
                <span><%= file[:status] %></span>
                <strong title="<%= file[:path] %>"><%= file[:path] %></strong>
              </div>
            <% end %>
          </div>
          <% if @change_request %>
            <%= link_to change_request_path(@change_request), class: "app-btn app-btn-muted mt-3" do %>
              <%= lucide_icon("code", class_name: "app-icon") %>
              <span>Open code review</span>
            <% end %>
          <% end %>
        <% else %>
          <p class="run-review-empty">No changed files have been captured yet.</p>
        <% end %>

        <div class="run-review-visuals">
          <h3>Visual review</h3>
          <% if visual_artifacts.any? %>
            <% visual_artifacts.first(4).each do |artifact| %>
              <div>
                <%= lucide_icon("image", class_name: "app-icon") %>
                <span><%= artifact.name %></span>
              </div>
            <% end %>
          <% else %>
            <p>No visual artifact captured yet. Ask Codex for a screenshot or browser check when UI changes are involved.</p>
          <% end %>
        </div>
      </article>

      <details class="run-review-panel run-review-activity">
        <summary>
          <span>
            <small class="app-eyebrow">Activity</small>
            <strong>Step evidence and logs</strong>
          </span>
          <em><%= completed_steps %>/<%= @steps.size %></em>
        </summary>
        <div class="run-review-progress" aria-label="Run progress">
          <span style="width: <%= progress_percent %>%"></span>
        </div>
        <div class="run-review-step-list">
          <% @steps.each do |step| %>
            <% input = step.input_json || {} %>
            <% output = step.output_json || {} %>
            <% step_messages = @messages_by_step_id.fetch(step.id, []) %>
            <% step_logs = @logs_by_step_id.fetch(step.id, []) %>
            <% step_artifacts = @artifacts_by_step_id.fetch(step.id, []) %>
            <% provider = (step.action_definition&.provider || step.action_snapshot.to_h["provider"] || "provider").to_s.tr("_", " ").titleize %>
            <% step_summary = output["summary"].presence || step.error_message.presence || input["objective"].presence || step.action_definition&.execution_guidance.presence || step.action_definition&.name.presence || "Step recorded." %>
            <article id="<%= step_anchor(step) %>" class="<%= "is-current" if step == current_step %>">
              <div class="run-review-step-head">
                <%= status_icon_pill(step.status, title: step.display_status) %>
                <span>
                  <strong><%= step.name %></strong>
                  <small><%= provider %> · <%= step.display_status %></small>
                </span>
              </div>
              <p><%= step_summary %></p>
              <% if output.key?("changed_files_count") || output["branch_name"].present? %>
                <div class="run-review-mini-chips">
                  <% if output.key?("changed_files_count") %>
                    <span><%= pluralize(output["changed_files_count"], "changed file") %></span>
                  <% end %>
                  <% if output["branch_name"].present? %>
                    <span title="<%= output["branch_name"] %>"><%= output["branch_name"] %></span>
                  <% end %>
                </div>
              <% end %>
              <% if agent_trace_available?(step, messages: step_messages, logs: step_logs, artifacts: step_artifacts) %>
                <%= render "agent_trace", step: step, messages: step_messages, logs: step_logs, artifacts: step_artifacts %>
              <% end %>
            </article>
          <% end %>
        </div>
      </details>

      <article class="run-review-panel run-review-conversation">
        <header>
          <div>
            <p class="app-eyebrow">Conversation</p>
            <h2>Ask Codex or leave context</h2>
          </div>
          <span class="linear-count"><%= CodexSession.runtime_label(codex_chat_runtime) %></span>
        </header>

        <div class="run-review-thread" data-run-chat-target="stream">
          <article class="codex-chat-bubble is-user">
            <div class="codex-chat-bubble-head">
              <span>Operator</span>
              <span>Objective</span>
            </div>
            <p><%= objective_text %></p>
          </article>

          <% @run_messages.each do |message| %>
            <article id="run-message-<%= message.id %>" class="codex-chat-bubble is-<%= message.role %> <%= "is-pending" if message.pending? %>">
              <div class="codex-chat-bubble-head">
                <span><%= message.role == "user" ? (message.user&.display_name || "You") : "xmode" %></span>
                <span><%= message.pending? ? decision_label : message.kind.to_s.tr("_", " ") %></span>
              </div>
              <% if message.content.present? %>
                <p><%= message.content %></p>
              <% end %>
              <% if message.kind == "goal_check" && message.payload["checks"].present? %>
                <ul class="codex-chat-checks">
                  <% message.payload["checks"].each do |check| %>
                    <li><%= check %></li>
                  <% end %>
                </ul>
              <% end %>
              <% message_usage = run_message_usage_items(message) %>
              <% if message_usage.any? || message.payload["summary"].present? || message.payload["plan"].present? %>
                <div class="codex-message-payload">
                  <% if message.payload["summary"].present? %>
                    <p><strong>Summary</strong><span><%= message.payload["summary"] %></span></p>
                  <% end %>
                  <% if message.payload["plan"].present? %>
                    <details>
                      <summary>Plan</summary>
                      <div class="rich-markdown codex-agent-markdown mt-2">
                        <%= render_markdown(message.payload["plan"]) %>
                      </div>
                    </details>
                  <% end %>
                  <% if message_usage.any? %>
                    <div class="codex-agent-usage" aria-label="Message token usage">
                      <% message_usage.each do |label, value| %>
                        <span><strong><%= value %></strong> <%= label %></span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>

          <%= render "codex_session_thread", codex_sessions: @codex_sessions %>

          <% if @run_messages.blank? && @codex_sessions.blank? %>
            <article class="codex-chat-bubble is-assistant">
              <div class="codex-chat-bubble-head">
                <span>xmode</span>
                <span><%= @run.display_status %></span>
              </div>
              <p>No conversation has been added yet.</p>
            </article>
          <% end %>
        </div>

        <footer class="run-review-composer">
          <% if permitted?("run_code_actions") %>
            <%= form_with url: pipeline_run_codex_messages_path(@run),
                  class: "codex-chat-composer-form",
                  data: { action: "turbo:submit-start->run-chat#composerSubmitStart turbo:submit-end->run-chat#composerSubmitEnd" } do |form| %>
              <div class="codex-chat-composer-box">
                <%= form.text_area :content,
                      rows: 1,
                      class: "app-textarea codex-chat-input",
                      placeholder: "Ask Codex to inspect, revise, screenshot, explain, or continue...",
                      data: {
                        run_chat_target: "input",
                        action: "input->run-chat#autosize keydown->run-chat#submitOnEnter"
                      } %>
                <div class="codex-chat-composer-tools">
                  <span>Codex · <%= CodexSession.runtime_label(codex_chat_runtime) %> · <%= codex_chat_model %></span>
                  <%= form.button class: "app-btn app-btn-primary", title: "Ask Codex", aria: { label: "Ask Codex" } do %>
                    <%= lucide_icon("message-square", class_name: "app-icon") %>
                    <span>Ask Codex</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="run-review-empty">Codex chat requires code action access.</p>
          <% end %>
          <% if @can_cancel %>
            <%= button_to cancel_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-danger" do %>
              <%= lucide_icon("ban", class_name: "app-icon") %>
              <span>Cancel run</span>
            <% end %>
          <% end %>
        </footer>
      </article>
    </section>
  </main>

  <aside class="run-review-rail">
    <section>
      <p class="app-eyebrow">Decision</p>
      <h3><%= decision_label %></h3>
      <p><%= decision_summary %></p>
      <% if @change_request %>
        <%= link_to change_request_path(@change_request), class: "run-review-rail-link" do %>
          <%= status_icon_pill(@change_request.status, title: @change_request.status.to_s.titleize) %>
          <span>
            <strong><%= @change_request.title %></strong>
            <small title="<%= @change_request.branch_name %>"><%= @change_request.branch_name %></small>
          </span>
        <% end %>
      <% end %>
    </section>

    <section>
      <p class="app-eyebrow">Evidence</p>
      <h3>Review signals</h3>
      <div class="run-review-signal-grid">
        <div><strong><%= @approvals.size %></strong><span>approvals</span></div>
        <div><strong><%= @sandbox_sessions.size %></strong><span>sandboxes</span></div>
        <div><strong><%= @artifacts.size %></strong><span>artifacts</span></div>
        <div><strong><%= @logs.size %></strong><span>logs</span></div>
      </div>
    </section>

    <% if @sandbox_sessions.any? %>
      <section>
        <p class="app-eyebrow">Sandboxes</p>
        <h3>Open workspaces</h3>
        <div class="run-review-rail-list">
          <% @sandbox_sessions.each do |sandbox| %>
            <% sandbox_files = @sandbox_files_by_session_id.fetch(sandbox.id, []) %>
            <% sandbox_name = sandbox.execution_environment&.name.presence || "Workspace sandbox" %>
            <%= link_to sandbox_session_path(sandbox) do %>
              <%= status_icon_pill(sandbox.status, title: sandbox.status.to_s.titleize) %>
              <span>
                <strong><%= sandbox_name %></strong>
                <small><%= sandbox.kind.to_s.tr("_", " ").titleize %><% if sandbox_files.any? %> · <%= pluralize(sandbox_files.size, "file") %><% end %></small>
              </span>
            <% end %>
            <% if sandbox_files.any? || sandbox.sandbox_commands.any? %>
              <details class="run-review-sandbox-details">
                <summary>Files and terminal</summary>
                <% if sandbox_files.any? %>
                  <div class="sandbox-file-list">
                    <% sandbox_files.first(5).each do |file| %>
                      <div class="sandbox-file-row">
                        <%= lucide_icon(file.fetch(:type) == "directory" ? "folder" : "file", class_name: "app-icon") %>
                        <span class="sandbox-file-name"><%= file.fetch(:path) %></span>
                        <span class="sandbox-file-meta"><%= file.fetch(:type).to_s.titleize %></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
                <% if sandbox.sandbox_commands.any? %>
                  <div class="sandbox-terminal">
                    <div class="sandbox-terminal-head">
                      <span>Terminal</span>
                      <span><%= pluralize(sandbox.sandbox_commands.size, "command") %></span>
                    </div>
                    <% sandbox.sandbox_commands.order(created_at: :desc).first(3).each do |command| %>
                      <div class="sandbox-command-row">
                        <div class="sandbox-command-line">
                          <code>$ <%= command.command %></code>
                          <%= status_icon_pill(command.status, title: command.status.to_s.titleize) %>
                        </div>
                        <% if command.stdout.present? %>
                          <pre><%= command.stdout %></pre>
                        <% elsif command.stderr.present? %>
                          <pre class="is-error"><%= command.stderr %></pre>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </details>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <details class="run-review-raw">
      <summary>
        <span>Raw evidence</span>
        <small><%= pluralize(@artifacts.size, "artifact") %>, <%= pluralize(@logs.size, "log") %></small>
      </summary>
      <div class="run-review-raw-list">
        <% @artifacts.each do |artifact| %>
          <% preview = artifact_text_preview(artifact) %>
          <details>
            <summary>
              <span><%= artifact.name %></span>
              <small><%= artifact.byte_size.present? ? number_to_human_size(artifact.byte_size) : artifact.content_type.presence || "saved" %></small>
            </summary>
            <% if preview.present? && artifact.content_type == "text/markdown" %>
              <div class="record-artifact-preview rich-markdown mt-3">
                <%= render_markdown(preview) %>
              </div>
            <% elsif preview.present? && (artifact.content_type&.start_with?("text/") || artifact.content_type == "application/json" || artifact.content_type == "text/x-patch") %>
              <pre class="record-artifact-preview mt-3 overflow-auto rounded-md bg-muted/35 p-3 text-xs text-muted-foreground"><%= preview %></pre>
            <% else %>
              <p class="mt-2 text-xs text-muted-foreground">Preview unavailable.</p>
            <% end %>
          </details>
        <% end %>
        <% @logs.last(8).each do |log| %>
          <article>
            <%= status_icon_pill(log.level, title: log.level.to_s.titleize) %>
            <span><%= log.message %></span>
          </article>
        <% end %>
      </div>
    </details>
  </aside>
</div>
