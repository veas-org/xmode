<% content_for :page_title, "Run ##{@run.id}" %>
<% run_name = @run.pipeline_definition&.name || "Pipeline run" %>
<% target_label = @run.issue&.identifier || @run.project&.title || @run.event&.title || "workspace run" %>
<% run_context = (@run.input_context || {}).to_h %>
<% objective_text = run_context["objective"].presence || @steps.map { |step| (step.input_json || {}).to_h["objective"].presence }.compact.first || @run.issue&.title || "Objective not captured yet." %>
<% plan_text = run_context["plan"].presence || @steps.map { |step| (step.input_json || {}).to_h["plan"].presence }.compact.first || "Plan will be captured before execution continues." %>
<% current_step = @steps.find { |step| step.status.in?(%w[running waiting_for_approval waiting_for_input]) } || @steps.last %>
<% completed_steps = @steps.count { |step| step.status == "completed" } %>
<% failed_steps = @steps.count { |step| step.status.in?(%w[failed canceled]) } %>
<% command_count = @sandbox_sessions.sum { |sandbox| sandbox.sandbox_commands.size } %>
<% evidence_total = @artifacts.size + @logs.size + @sandbox_sessions.size + @approvals.size + @run_messages.size %>
<% next_label = if @pending_run_message
  "Answer required"
elsif @pending_approval
  "Approval required"
elsif @run.status == "completed"
  "Ready for review"
else
  @run.display_status
end %>
<% run_summary = if @run.error_message.present?
  @run.error_message
elsif current_step&.output_json.to_h["summary"].present?
  current_step.output_json["summary"]
elsif @run.status == "completed"
  "Run completed with #{pluralize(completed_steps, "completed step")} and #{pluralize(evidence_total, "evidence item")}."
elsif current_step
  "#{current_step.name} is the current focus."
else
  "Run is waiting for its first step."
end %>
<% evidence_rows = [
  [ "Approvals", pluralize(@approvals.size, "gate"), @approvals.any? { |approval| approval.status == "pending" } ? "pending" : (@approvals.any? ? "captured" : "none captured") ],
  [ "Sandbox", pluralize(@sandbox_sessions.size, "session"), @sandbox_sessions.any? ? "#{pluralize(command_count, "command")}" : "not opened" ],
  [ "Artifacts", pluralize(@artifacts.size, "file"), @artifacts.first&.name || "none captured" ],
  [ "Logs", pluralize(@logs.size, "entry"), @logs.last&.message || "none captured" ],
  [ "Run chat", pluralize(@run_messages.size, "message"), @pending_run_message ? "answer required" : (@run_messages.last&.content || "quiet") ]
] %>

<div class="record-detail-layout run-review-layout">
  <main class="record-detail-main run-review-main">
    <header class="record-doc-hero run-review-hero">
      <div class="run-review-hero-top">
        <div class="flex min-w-0 flex-wrap items-center gap-2">
          <span class="linear-count">Run #<%= @run.id %></span>
          <%= status_icon_pill(@run.status, title: @run.display_status) %>
          <span class="linear-count"><%= target_label %></span>
          <span class="linear-count"><%= @run.display_trigger %></span>
        </div>
      </div>

      <h2 class="record-detail-page-title"><%= run_name %></h2>
      <p class="run-review-summary"><%= run_summary %></p>

      <div class="record-detail-page-actions">
        <% if @run.issue %>
          <%= link_to issue_path(@run.issue), class: "app-btn app-btn-muted" do %>
            <%= lucide_icon("circle-dot", class_name: "app-icon") %>
            <span><%= @run.issue.identifier %></span>
          <% end %>
        <% end %>
        <% if @change_request %>
          <%= link_to change_request_path(@change_request), class: "app-btn app-btn-primary" do %>
            <%= lucide_icon("git-pull-request", class_name: "app-icon") %>
            <span>Change Request</span>
          <% end %>
        <% end %>
      </div>
    </header>

    <section class="record-detail-section run-review-brief-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Run brief</p>
          <h3>Objective and plan</h3>
        </div>
        <span class="linear-count"><%= completed_steps %>/<%= @steps.size %> steps</span>
      </div>

      <div class="run-review-brief-grid">
        <article>
          <span>Objective</span>
          <p><%= objective_text %></p>
        </article>
        <article>
          <span>Plan</span>
          <p><%= plan_text %></p>
        </article>
      </div>
    </section>

    <section class="record-detail-section run-review-timeline-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Execution</p>
          <h3>Most relevant steps</h3>
          <p class="mt-1 text-sm leading-6 text-muted-foreground">
            <%= pluralize(completed_steps, "completed step") %><% if failed_steps.positive? %>, <%= pluralize(failed_steps, "failed step") %><% end %>, <%= pluralize(evidence_total, "evidence item") %>.
          </p>
        </div>
        <span class="linear-count">Snapshot <%= pluralize(@snapshot_nodes.size, "step") %></span>
      </div>

      <ol class="run-review-step-list">
        <% @steps.each do |step| %>
          <% input = step.input_json || {} %>
          <% output = step.output_json || {} %>
          <% provider = (step.action_definition&.provider || step.action_snapshot.to_h["provider"] || "provider").to_s.tr("_", " ").titleize %>
          <% duration = if step.started_at.present? && step.finished_at.present?
            distance_of_time_in_words(step.started_at, step.finished_at)
          elsif step.started_at.present?
            "#{time_ago_in_words(step.started_at)} running"
          else
            "not started"
          end %>
          <% skill_label = if input.dig("skill", "name").present?
            [ input.dig("skill", "name"), input.dig("skill", "version").present? ? "@#{input.dig("skill", "version")}" : nil ].compact.join(" ")
          end %>
          <% step_summary = output["summary"].presence || step.error_message.presence || input["objective"].presence || step.action_definition&.description.presence || "Step recorded." %>

          <li class="run-review-step">
            <div class="run-review-step-marker">
              <%= status_icon_pill(step.status, title: step.display_status) %>
            </div>
            <article>
              <header>
                <div class="min-w-0">
                  <h4><%= step.name %></h4>
                  <p><%= provider %> · <%= duration %><% if skill_label.present? %> · <%= skill_label %><% end %></p>
                </div>
                <span class="linear-count">Step <%= step.position + 1 %></span>
              </header>

              <p class="run-review-step-summary <%= "is-danger" if step.error_message.present? %>"><%= step_summary %></p>

              <% if output["status"].present? || output.key?("changed_files_count") || output["branch_name"].present? %>
                <div class="run-review-step-metrics">
                  <% if output["status"].present? %>
                    <span><%= output["status"].to_s.tr("_", " ").titleize %></span>
                  <% end %>
                  <% if output.key?("changed_files_count") %>
                    <span><%= pluralize(output["changed_files_count"], "changed file") %></span>
                  <% end %>
                  <% if output["branch_name"].present? %>
                    <span title="<%= output["branch_name"] %>"><%= output["branch_name"] %></span>
                  <% end %>
                </div>
              <% end %>
            </article>
          </li>
        <% end %>
      </ol>
    </section>
  </main>

  <aside class="record-detail-side run-review-side">
    <section class="record-detail-section run-review-now-section <%= "is-action-required" if @pending_run_message || @pending_approval %>">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Now</p>
          <h3><%= next_label %></h3>
        </div>
        <%= status_icon_pill(@pending_run_message ? "waiting_for_input" : @run.status, title: next_label) %>
      </div>

      <% if current_step %>
        <p class="run-review-side-copy"><%= current_step.name %></p>
      <% end %>

      <% if @pending_run_message %>
        <article class="run-interaction">
          <span><%= @pending_run_message.kind.to_s.tr("_", " ").titleize %></span>
          <p><%= @pending_run_message.content %></p>

          <% if @pending_run_message.kind == "goal_check" && @pending_run_message.payload["checks"].present? %>
            <ul class="run-chat-checks">
              <% @pending_run_message.payload["checks"].each do |check| %>
                <li><%= check %></li>
              <% end %>
            </ul>
          <% end %>

          <% if @pending_run_message.choices.any? %>
            <div class="run-chat-actions">
              <% @pending_run_message.choices.each do |choice| %>
                <% choice_key = choice["key"].to_s %>
                <% choice_button_class = if choice_key.match?(/approve|accept|continue|yes/)
                  "app-btn app-btn-primary"
                elsif choice_key.match?(/reject|cancel|stop|no/)
                  "app-btn app-btn-danger"
                else
                  "app-btn app-btn-muted"
                end %>
                <%= button_to pipeline_run_run_message_path(@run, @pending_run_message),
                      method: :post,
                      params: { choice: choice["key"] },
                      class: choice_button_class do %>
                  <span><%= choice["label"].presence || choice["key"].to_s.humanize %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <%= form_with url: pipeline_run_run_message_path(@run, @pending_run_message), class: "run-chat-form" do |form| %>
              <%= form.text_area :content,
                    rows: 3,
                    class: "app-textarea",
                    placeholder: @pending_run_message.kind == "goal_check" ? "Add goal-check notes..." : "Reply with context..." %>
              <%= form.submit "Send", class: "app-btn app-btn-primary" %>
            <% end %>
          <% end %>
        </article>
      <% elsif @pending_approval %>
        <div class="run-control-actions">
          <%= button_to approve_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-primary" do %>
            <%= lucide_icon("check", class_name: "app-icon") %>
            <span>Approve</span>
          <% end %>
          <%= button_to reject_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-danger" do %>
            <%= lucide_icon("x", class_name: "app-icon") %>
            <span>Reject</span>
          <% end %>
        </div>
      <% else %>
        <p class="run-review-side-copy">No manual response is required right now.</p>
      <% end %>

      <details class="run-follow-up">
        <summary>Add instruction</summary>
        <%= form_with url: pipeline_run_run_messages_path(@run), class: "run-chat-form" do |form| %>
          <%= form.text_area :content,
                rows: 3,
                class: "app-textarea",
                placeholder: "Constraint, context, or follow-up..." %>
          <%= form.submit "Add", class: "app-btn app-btn-muted" %>
        <% end %>
      </details>

      <% if @can_resume || @can_cancel %>
        <div class="run-control-actions">
          <% if @can_resume %>
            <%= button_to resume_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-muted" do %>
              <%= lucide_icon("rotate-cw", class_name: "app-icon") %>
              <span>Resume</span>
            <% end %>
          <% end %>
          <% if @can_cancel %>
            <%= button_to cancel_pipeline_run_path(@run), method: :post, class: "app-btn app-btn-danger" do %>
              <%= lucide_icon("ban", class_name: "app-icon") %>
              <span>Cancel</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="record-detail-section run-review-context-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Context</p>
          <h3>Run context</h3>
        </div>
      </div>
      <div class="cr-context-strip">
        <div>
          <span>Trigger</span>
          <strong><%= @run.display_trigger %></strong>
        </div>
        <div>
          <span>Project</span>
          <strong title="<%= @run.project&.title %>"><%= @run.project&.title || "-" %></strong>
        </div>
        <div>
          <span>Issue</span>
          <strong><%= @run.issue&.identifier || "-" %></strong>
        </div>
        <div>
          <span>Event</span>
          <strong title="<%= @run.event&.title %>"><%= @run.event&.title || "-" %></strong>
        </div>
        <div>
          <span>Snapshot</span>
          <strong><%= pluralize(@snapshot_nodes.size, "step") %></strong>
        </div>
      </div>
    </section>

    <section class="record-detail-section run-review-evidence-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Evidence</p>
          <h3>Evidence rollup</h3>
        </div>
        <span class="linear-count"><%= pluralize(evidence_total, "item") %></span>
      </div>

      <div class="run-review-evidence-list">
        <% evidence_rows.each do |label, count, detail| %>
          <article class="run-review-evidence-row">
            <%= status_icon_pill(detail, title: "#{label}: #{detail.to_s.tr("_", " ").titleize}") %>
            <span>
              <strong><%= label %></strong>
              <small><%= count %> · <%= detail %></small>
            </span>
          </article>
        <% end %>
      </div>
    </section>

    <section class="record-detail-section run-review-context-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Review package</p>
          <h3>Change Request</h3>
        </div>
      </div>
      <% if @change_request %>
        <%= link_to change_request_path(@change_request), class: "run-review-change-request" do %>
          <%= status_icon_pill(@change_request.status, title: @change_request.status.to_s.titleize) %>
          <span>
            <strong><%= @change_request.title %></strong>
            <small title="<%= @change_request.branch_name %>"><%= @change_request.branch_name %></small>
          </span>
        <% end %>
      <% else %>
        <p class="run-review-side-copy">No Change Request yet.</p>
      <% end %>
    </section>

    <details class="cr-technical-appendix run-review-appendix">
      <summary>
        <span>Evidence appendix</span>
        <small><%= pluralize(@approvals.size, "approval") %>, <%= pluralize(@sandbox_sessions.size, "sandbox") %>, <%= pluralize(@artifacts.size, "artifact") %>, <%= pluralize(@logs.size, "log") %></small>
      </summary>

      <div class="cr-appendix-grid">
        <section class="cr-appendix-section">
          <h3>Approvals</h3>
          <% if @approvals.any? %>
            <div class="cr-verification-list">
              <% @approvals.each do |approval| %>
                <article class="cr-verification-row">
                  <%= status_icon_pill(approval.status, title: approval.display_status) %>
                  <div class="min-w-0">
                    <strong><%= approval.action_run_step&.name || "Manual gate" %></strong>
                    <p><%= approval.user&.display_name || "No reviewer recorded" %> · <%= approval.display_status %></p>
                    <% if approval.notes.present? %>
                      <p><%= approval.notes %></p>
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No approvals recorded.</p>
          <% end %>
        </section>

        <section class="cr-appendix-section">
          <h3>Sandboxes</h3>
          <% if @sandbox_sessions.any? %>
            <div class="cr-appendix-items">
              <% @sandbox_sessions.each do |sandbox| %>
                <% files = @sandbox_files_by_session_id.fetch(sandbox.id, []) %>
                <% environment = sandbox.execution_environment %>
                <details class="cr-appendix-item">
                  <summary>
                    <span><%= sandbox.kind.to_s.tr("_", " ").titleize %></span>
                    <small><%= sandbox.status.titleize %> · <%= pluralize(files.size, "file") %></small>
                  </summary>
                  <p class="mt-2 text-xs leading-5 text-muted-foreground">
                    <%= environment&.name || "Workspace sandbox" %>
                    · <%= sandbox.action_run_step&.name || "Run sandbox" %>
                    · <%= environment&.docker? ? environment.docker_image : "host runtime" %>
                  </p>
                  <% if sandbox.worktree_path.present? %>
                    <p class="mt-2 break-all text-xs leading-5 text-muted-foreground">Worktree: <%= sandbox.worktree_path %></p>
                  <% end %>
                  <% if files.any? %>
                    <div class="sandbox-file-list">
                      <% files.each do |file| %>
                        <div class="sandbox-file-row">
                          <%= lucide_icon(file.fetch(:type) == "directory" ? "folder" : "file", class_name: "app-icon text-muted-foreground") %>
                          <span class="sandbox-file-name"><%= file.fetch(:path) %></span>
                          <span class="sandbox-file-meta"><%= file.fetch(:byte_size).present? ? number_to_human_size(file.fetch(:byte_size)) : "folder" %></span>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                  <div class="sandbox-terminal">
                    <div class="sandbox-terminal-head">
                      <span>Terminal</span>
                      <span><%= pluralize(sandbox.sandbox_commands.size, "command") %></span>
                    </div>
                    <% sandbox.sandbox_commands.order(created_at: :desc).first(3).each do |command| %>
                      <article class="sandbox-command-row">
                        <div class="sandbox-command-line">
                          <code>$ <%= command.command %></code>
                          <%= status_icon_pill(command.status, title: command.status.titleize) %>
                        </div>
                        <% if command.stdout.present? %>
                          <pre><%= command.stdout %></pre>
                        <% end %>
                        <% if command.stderr.present? %>
                          <pre class="is-error"><%= command.stderr %></pre>
                        <% end %>
                      </article>
                    <% end %>
                    <% if sandbox.worktree_path.present? && sandbox.status.in?(%w[ready running]) %>
                      <%= form_with url: pipeline_run_sandbox_session_commands_path(@run, sandbox), class: "sandbox-command-form" do |form| %>
                        <%= text_field_tag :command, nil, class: "app-input", placeholder: "pwd, ls, cat README.md" %>
                        <%= form.submit "Run", class: "app-btn app-btn-muted" %>
                      <% end %>
                    <% end %>
                  </div>
                </details>
              <% end %>
            </div>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No sandbox sessions recorded.</p>
          <% end %>
        </section>

        <section class="cr-appendix-section">
          <h3>Artifacts</h3>
          <% if @artifacts.any? %>
            <div class="cr-appendix-items">
              <% @artifacts.each do |artifact| %>
                <% preview = artifact_text_preview(artifact) %>
                <details class="cr-appendix-item">
                  <summary>
                    <span><%= artifact.name %></span>
                    <small><%= artifact.byte_size.present? ? number_to_human_size(artifact.byte_size) : artifact.content_type.presence || "saved" %></small>
                  </summary>
                  <% if preview.present? && artifact.content_type == "text/markdown" %>
                    <div class="record-artifact-preview rich-markdown mt-3">
                      <%= render_markdown(preview) %>
                    </div>
                  <% elsif preview.present? && (artifact.content_type&.start_with?("text/") || artifact.content_type == "application/json" || artifact.content_type == "text/x-patch") %>
                    <pre class="record-artifact-preview mt-3 overflow-auto rounded-md bg-muted/35 p-3 text-xs text-muted-foreground"><%= preview %></pre>
                  <% else %>
                    <p class="mt-2 text-xs text-muted-foreground">Preview unavailable.</p>
                  <% end %>
                </details>
              <% end %>
            </div>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No artifacts recorded.</p>
          <% end %>
        </section>

        <section class="cr-appendix-section">
          <h3>Logs</h3>
          <% if @logs.any? %>
            <div class="cr-log-list">
              <% @logs.each do |log| %>
                <article>
                  <%= status_icon_pill(log.level, title: log.level.to_s.titleize) %>
                  <span><%= log.message %></span>
                  <small><%= time_ago_in_words(log.created_at) %> ago</small>
                </article>
              <% end %>
            </div>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No logs recorded.</p>
          <% end %>
        </section>

        <% if @run_messages.any? || @pending_run_message.present? %>
          <section class="cr-appendix-section cr-appendix-section-wide">
            <h3>Run chat</h3>
            <div class="run-chat-thread">
              <% @run_messages.each do |message| %>
                <article class="run-chat-message is-<%= message.role %> <%= "is-pending" if message.pending? %>">
                  <div class="run-chat-message-head">
                    <span><%= message.role == "user" ? (message.user&.display_name || "You") : "xmode" %></span>
                    <span><%= message.kind.to_s.tr("_", " ") %></span>
                  </div>
                  <% if message.content.present? %>
                    <p><%= message.content %></p>
                  <% end %>
                </article>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </details>
  </aside>
</div>
