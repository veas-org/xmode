<div id="<%= dom_id(codex_session, :pipeline_thread) %>">
  <% codex_session.codex_session_messages.chronological.each do |message| %>
    <article class="codex-chat-bubble is-user">
      <div class="codex-chat-bubble-head">
        <span><%= message.user&.display_name || "You" %></span>
        <span>Run chat</span>
      </div>
      <p><%= message.content %></p>
    </article>

    <% if message.response.present? %>
      <article class="codex-chat-bubble is-assistant <%= "is-danger" if message.failed? %>">
        <div class="codex-chat-bubble-head">
          <span>Codex</span>
          <span><%= codex_session.runtime_label %> · <%= message.display_status %></span>
        </div>
        <div class="rich-markdown codex-chat-markdown">
          <%= render "codex_sessions/response", response: message.response %>
        </div>
        <% if message.duration_ms.present? || message.metadata["command"].present? %>
          <div class="codex-chat-chips">
            <% if message.duration_ms.present? %>
              <span><%= number_with_delimiter(message.duration_ms) %> ms</span>
            <% end %>
            <% if message.metadata["command"].present? %>
              <span title="<%= Array(message.metadata["command"]).join(" ") %>"><%= codex_session.model %></span>
            <% end %>
          </div>
        <% end %>
      </article>
    <% elsif message.pending? %>
      <article class="codex-chat-bubble is-assistant is-pending">
        <div class="codex-chat-bubble-head">
          <span>Codex</span>
          <span><%= codex_session.runtime_label %> · <%= message.display_status %></span>
        </div>
        <p>Codex is working.</p>
      </article>
    <% end %>
  <% end %>

  <% if codex_session.last_error.present? %>
    <article class="codex-chat-bubble is-assistant is-danger">
      <div class="codex-chat-bubble-head">
        <span>Codex</span>
        <span><%= codex_session.display_status %></span>
      </div>
      <p><%= codex_session.last_error %></p>
    </article>
  <% end %>
</div>
