<% content_for :page_title, "Runs" %>

<div class="ops-page">
  <header class="ops-hero">
    <div class="min-w-0">
      <p class="app-eyebrow">Automation queue</p>
      <h1>Runs</h1>
      <p>Unified automation ledger across pipeline and swarm execution.</p>
      <div class="ops-summary" aria-label="Automation run summary">
        <span><strong><%= @runs.size %></strong> runs</span>
        <span><strong><%= @run_counts.fetch(:waiting) %></strong> waiting approval</span>
        <span><strong><%= @run_counts.fetch(:active) %></strong> active</span>
        <span><strong><%= @run_counts.fetch(:completed) %></strong> completed</span>
        <span><strong><%= @run_counts.fetch(:failed) %></strong> failed or canceled</span>
      </div>
    </div>
  </header>

  <div class="ops-layout">
    <section class="ops-section">
      <div class="ops-section-head">
        <div>
          <p class="app-eyebrow">Run ledger</p>
          <h2>Newest first</h2>
        </div>
        <span class="linear-count"><%= @runs.size %></span>
      </div>

      <div class="ops-list">
        <% @runs.each do |run| %>
          <%= link_to automation_execution_path(run), class: "ops-row" do %>
            <%= status_icon_pill(run.status, title: run.display_status) %>
            <span class="record-point-main">
              <span class="record-point-title"><%= run.display_title %></span>
              <span class="record-point-meta">
                <span><%= run.display_kind %></span>
                <span><%= run.display_trigger %></span>
                <span><%= run.display_target %></span>
                <% if run.change_request&.branch_name.present? %><span class="break-all"><%= run.change_request.branch_name %></span><% end %>
                <span><%= run.started_at ? "#{time_ago_in_words(run.started_at)} ago" : "#{time_ago_in_words(run.created_at)} ago" %></span>
                <span><%= pluralize(run.artifact_count, "artifact") %></span>
                <% if run.approval_count.positive? %><span><%= pluralize(run.approval_count, "approval") %></span><% end %>
              </span>
              <% if run.display_objective.present? %>
                <span class="mt-2 line-clamp-2 block text-xs leading-5 text-muted-foreground"><%= run.display_objective %></span>
              <% end %>
            </span>
            <% if run.change_request %>
              <span class="ops-row-trailing">
                <%= status_icon_pill(run.change_request.status, title: "#{run.change_request.status.to_s.titleize} Change Request") %>
                <span class="linear-count">CR</span>
              </span>
            <% end %>
          <% end %>
        <% end %>
        <% if @runs.empty? %>
          <p class="linear-empty px-0 py-6 text-left">No runs yet. Runs appear here after automation starts from a project, issue, schedule, event, or manual trigger.</p>
        <% end %>
      </div>
    </section>

    <aside class="ops-side">
      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Queue health</p>
            <h2>Status mix</h2>
          </div>
        </div>
        <dl class="ops-kv-list">
          <div><dt>Waiting approval</dt><dd><%= @run_counts.fetch(:waiting) %></dd></div>
          <div><dt>Queued or running</dt><dd><%= @run_counts.fetch(:active) %></dd></div>
          <div><dt>Completed</dt><dd><%= @run_counts.fetch(:completed) %></dd></div>
          <div><dt>Failed or canceled</dt><dd><%= @run_counts.fetch(:failed) %></dd></div>
        </dl>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Evidence chain</p>
            <h2>Trust boundary</h2>
          </div>
        </div>
        <div class="ops-list">
          <% [ "Objective captured", "Plan verified", "Steps executed", "Logs and artifacts attached", "Change Request linked" ].each_with_index do |item, index| %>
            <article class="ops-row">
              <span class="linear-count"><%= index + 1 %></span>
              <span class="record-point-main">
                <span class="record-point-title"><%= item %></span>
              </span>
            </article>
          <% end %>
        </div>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">A run is trusted only when the team can follow this chain from the original objective to reviewable code or a non-code artifact.</p>
      </section>

      <section class="ops-section">
        <div class="ops-section-head">
          <div>
            <p class="app-eyebrow">Trigger sources</p>
            <h2>How runs start</h2>
          </div>
        </div>
        <p class="text-sm leading-6 text-muted-foreground">Runs can start manually, from a schedule, from an event rule, or from a project pipeline. Code-changing runs always isolate work on a branch and package review in a Change Request.</p>
      </section>
    </aside>
  </div>
</div>
