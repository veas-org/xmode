<% content_for :page_title, "Cycles" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Sprint planning</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Time-boxed delivery windows that connect issues, priorities, owners, and automation runs.</p>
  </div>
  <%= link_to new_cycle_path, class: "app-btn app-btn-primary" do %>
    <%= lucide_icon("plus", class_name: "app-icon") %>
    <span>Cycle</span>
  <% end %>
</div>

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  <% @cycles.each do |cycle| %>
    <%= link_to cycle_path(cycle), class: "linear-surface block p-5 transition-colors hover:bg-muted/50" do %>
      <div class="flex items-start justify-between gap-3">
        <h2 class="font-semibold text-foreground"><%= cycle.name %></h2>
        <span class="status-pill"><%= cycle.status %></span>
      </div>
      <div class="mt-5 grid gap-2 text-sm">
        <div class="inbox-property"><span>Team</span><strong><%= cycle.team.name %></strong></div>
        <div class="inbox-property"><span>Window</span><strong><%= [ cycle.starts_on || "No start", cycle.ends_on || "No end" ].join(" - ") %></strong></div>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="status-pill"><%= pluralize(cycle.issues.count, "issue") %></span>
        <span class="status-pill"><%= pluralize(cycle.goals.count, "goal") %></span>
      </div>
    <% end %>
  <% end %>
</div>
