<% content_for :page_title, @issue.identifier %>
<div class="grid gap-6 lg:grid-cols-[1fr_340px]">
  <article class="app-card p-6">
    <p class="app-eyebrow"><%= @issue.display_status %> · <%= @issue.priority %></p>
    <h2 class="mt-2 text-3xl font-semibold text-foreground"><%= @issue.title %></h2>
    <p class="mt-5 whitespace-pre-wrap text-muted-foreground"><%= @issue.description.presence || "No description." %></p>
    <div class="mt-6 flex gap-2">
      <%= link_to "Edit", edit_issue_path(@issue), class: "app-btn app-btn-muted" %>
      <% current_workspace.pipeline_definitions.limit(3).each do |pipeline| %>
        <%= button_to "Run #{pipeline.name}", run_pipeline_path(pipeline, issue_id: @issue.id), method: :post, class: "app-btn app-btn-primary" %>
      <% end %>
    </div>
  </article>
  <aside class="space-y-4">
    <section class="app-card p-4">
      <h3 class="font-medium text-foreground">Details</h3>
      <dl class="mt-3 space-y-2 text-sm text-muted-foreground">
        <div class="flex justify-between"><dt>Project</dt><dd><%= @issue.project&.title || "-" %></dd></div>
        <div class="flex justify-between"><dt>Cycle</dt><dd><%= @issue.cycle&.name || "-" %></dd></div>
        <div class="flex justify-between"><dt>Assignee</dt><dd><%= @issue.assignee&.display_name || "-" %></dd></div>
        <div class="flex justify-between"><dt>Estimate</dt><dd><%= @issue.estimate || "-" %></dd></div>
      </dl>
    </section>
    <section class="app-card p-4">
      <h3 class="font-medium text-foreground">Change Requests</h3>
      <div class="mt-3 space-y-2">
        <% @change_requests.each do |cr| %>
          <%= link_to cr.title, change_request_path(cr), class: "block text-sm text-foreground" %>
        <% end %>
        <% if @change_requests.empty? %><p class="text-sm text-muted-foreground">None yet.</p><% end %>
      </div>
    </section>
  </aside>
</div>
