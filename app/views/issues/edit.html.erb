        title: "Edit #{@issue.identifier}",
        eyebrow: "Issue details",
        description: "Update scope, status, priority, and acceptance context without leaving the issue flow.",
        back_path: issue_path(@issue),
        wide: true
      } do %>
  <%= render "form", issue: @issue %>
<% end %>
