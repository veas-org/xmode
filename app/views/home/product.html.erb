<% content_for :title, "Product - xmode" %>
<section class="mx-auto max-w-7xl px-5 py-16">
  <p class="app-eyebrow">Product</p>
  <h1 class="mt-4 text-4xl font-semibold text-white">Project management with automation as a first-class workflow.</h1>
  <div class="mt-10 grid gap-4 md:grid-cols-3">
    <% [
      [ "Linear-style work", "Issues, projects, cycles, priorities, labels, views, and Change Requests." ],
      [ "Reusable actions", "Typed JSON input/output actions for planning, coding, verification, review, release, and incidents." ],
      [ "Visual pipelines", "Canvas-based workflows with conditional edges, manual approvals, schedules, and event triggers." ]
    ].each do |title, body| %>
      <article class="app-card p-5">
        <h2 class="font-semibold text-white"><%= title %></h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400"><%= body %></p>
      </article>
    <% end %>
  </div>
</section>
