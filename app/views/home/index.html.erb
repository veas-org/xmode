<% content_for :title, "xmode - Open source software automation" %>
<section class="mx-auto grid min-h-[calc(100vh-73px)] max-w-7xl items-center gap-10 px-5 py-16 lg:grid-cols-[1.1fr_.9fr]">
  <div>
    <p class="app-eyebrow">AGPL-3.0 open source project</p>
    <h1 class="mt-5 max-w-4xl text-5xl font-semibold tracking-tight text-foreground md:text-7xl">Self-hostable software automation for agentic teams.</h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-muted-foreground">xmode is the open application behind project management, skills, actions, pipelines, approvals, sandboxed runs, and Change Requests. The commercial landing site lives separately so this repo stays clean for contributors and self-hosters.</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Create workspace", signup_path, class: "app-btn app-btn-primary" %>
      <%= button_to "Explore demo",
            demo_login_path(workspace: "planet-express"),
            method: :post,
            form: { class: "inline-block", data: { turbo: false } },
            class: "app-btn app-btn-muted" %>
    </div>
    <p class="mt-4 text-sm text-muted-foreground">
      <%= link_to "Read docs", docs_path, class: "hover:text-foreground" %>
      <% if landing_url.present? %>
        <span class="px-2 text-muted-foreground">/</span><%= link_to "Commercial site", landing_url, class: "hover:text-foreground" %>
      <% end %>
    </p>
  </div>
  <div class="app-card p-5">
    <div class="flex items-center justify-between gap-3">
      <span class="text-sm font-medium text-foreground">Open automation loop</span>
      <span class="status-pill">oss</span>
    </div>
    <div class="mt-4 space-y-1">
      <% [ "Objective", "Plan", "Skill", "Action", "Run", "Change Request" ].each_with_index do |step, index| %>
        <div class="app-flat-row flex items-center gap-3">
          <span class="grid h-7 w-7 place-items-center rounded-md text-xs font-medium <%= index < 2 ? 'bg-primary text-primary-foreground' : 'bg-muted text-muted-foreground' %>"><%= index + 1 %></span>
          <span class="text-sm text-foreground"><%= step %></span>
        </div>
      <% end %>
    </div>
  </div>
</section>
