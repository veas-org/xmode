<% content_for :page_title, "Projects" %>
<div class="mb-5 flex justify-end"><%= link_to "New project", new_project_path, class: "app-btn app-btn-primary" %></div>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  <% @projects.each do |project| %>
    <%= link_to project_path(project), class: "app-card block p-5 hover:bg-muted/50" do %>
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-foreground"><%= project.title %></h2>
        <span class="status-pill"><%= project.status %></span>
      </div>
      <p class="mt-3 line-clamp-3 text-sm text-muted-foreground"><%= project.description.presence || "No description." %></p>
      <p class="mt-4 text-xs text-muted-foreground"><%= project.issues.count %> issues · <%= project.repository_url.presence || "No repository" %></p>
    <% end %>
  <% end %>
</div>
