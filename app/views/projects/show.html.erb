<% content_for :page_title, @project.title %>
<div class="app-page-actions">
  <div class="min-w-0">
    <p class="app-eyebrow"><%= @project.key %> · <%= @project.status %></p>
    <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">
      Project command surface for issue scope, repository policy, scheduled automation, recent runs, and Change Request evidence.
    </p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to edit_project_path(@project), class: "app-btn app-btn-muted", data: side_panel_data do %>
      <%= lucide_icon("pencil", class_name: "app-icon") %>
      <span>Edit</span>
    <% end %>
    <%= link_to new_issue_path(project_id: @project.id), class: "app-btn app-btn-primary", data: side_panel_data do %>
      <%= lucide_icon("plus", class_name: "app-icon") %>
      <span>Issue</span>
    <% end %>
  </div>
</div>

<div class="app-detail-grid">
  <div class="space-y-5">
    <section class="linear-surface p-5">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="app-eyebrow">Project brief</p>
          <h2 class="mt-1 font-semibold text-foreground"><%= @project.title %></h2>
        </div>
        <span class="status-pill"><%= @project.status.to_s.titleize %></span>
      </div>
      <div class="rich-markdown mt-4 max-w-3xl">
        <%= render_markdown(@project.description, empty: "No project brief has been added yet.") %>
      </div>
    </section>

    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex min-w-0 items-center gap-2">
          <%= lucide_icon("list", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Issue flow</h2>
          <span class="linear-count"><%= pluralize(@issues.size, "issue") %></span>
        </div>
      </div>
      <%= render "issues/table", issues: @issues %>
    </section>
  </div>

  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Repository</h3>
      <dl class="mt-3 grid gap-2 text-sm">
        <div class="inbox-property"><dt>Team</dt><dd><strong><%= @project.team.name %></strong></dd></div>
        <div class="inbox-property"><dt>Key</dt><dd><strong><%= @project.key %></strong></dd></div>
        <div class="app-flat-row">
          <dt class="app-eyebrow">URL</dt>
          <dd class="mt-1 break-all text-sm font-medium text-foreground"><%= @project.repository_url.presence || "-" %></dd>
        </div>
      </dl>
    </section>

    <section class="linear-surface p-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="font-medium text-foreground">Scheduled pipelines</h3>
        <span class="linear-count"><%= @schedules.size %></span>
      </div>
      <div class="mt-3 space-y-2">
        <% @schedules.each do |schedule| %>
          <%= link_to schedule_path(schedule), class: "app-flat-row block rounded-md px-3 py-3 transition-colors hover:bg-muted/45" do %>
            <span class="flex min-w-0 items-start justify-between gap-3">
              <span class="min-w-0">
                <span class="block text-sm font-medium text-foreground"><%= schedule.pipeline_definition.name %></span>
                <span class="linear-row-meta">
                  <%= lucide_icon("clock", class_name: "app-icon") %>
                  <span><%= schedule.kind.to_s.tr("_", " ").titleize %></span>
                  <span><%= schedule.run_at&.strftime("%b %-d, %-I:%M %p") || schedule.cron %></span>
                </span>
              </span>
              <span class="status-pill shrink-0"><%= schedule.status.to_s.titleize %></span>
            </span>
          <% end %>
        <% end %>
        <% if @schedules.empty? %>
          <p class="linear-empty">No project schedules yet.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface p-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="font-medium text-foreground">Recent runs</h3>
        <span class="linear-count"><%= @runs.size %></span>
      </div>
      <div class="mt-3 space-y-2">
        <% @runs.each do |run| %>
          <%= link_to pipeline_run_path(run), class: "app-flat-row block rounded-md px-3 py-3 transition-colors hover:bg-muted/45" do %>
            <span class="flex min-w-0 items-start justify-between gap-3">
              <span class="min-w-0">
                <span class="block text-sm font-medium text-foreground"><%= run.pipeline_definition&.name || "Pipeline run" %></span>
                <span class="linear-row-meta">
                  <%= lucide_icon(run.status == "completed" ? "check" : "activity", class_name: "app-icon") %>
                  <span><%= run.display_trigger %></span>
                  <span><%= time_ago_in_words(run.created_at) %> ago</span>
                </span>
              </span>
              <span class="status-pill shrink-0"><%= run.display_status %></span>
            </span>
          <% end %>
        <% end %>
        <% if @runs.empty? %>
          <p class="linear-empty">No project runs yet.</p>
        <% end %>
      </div>
    </section>

    <section class="linear-surface p-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="font-medium text-foreground">Change Requests</h3>
        <span class="linear-count"><%= @change_requests.size %></span>
      </div>
      <div class="mt-3 space-y-2">
        <% @change_requests.each do |change_request| %>
          <%= link_to change_request_path(change_request), class: "app-flat-row block rounded-md px-3 py-3 transition-colors hover:bg-muted/45" do %>
            <span class="flex min-w-0 items-start justify-between gap-3">
              <span class="min-w-0">
                <span class="block text-sm font-medium leading-5 text-foreground"><%= change_request.title %></span>
                <span class="linear-row-meta">
                  <%= lucide_icon("git-pull-request", class_name: "app-icon") %>
                  <span class="break-all"><%= change_request.branch_name %></span>
                </span>
              </span>
              <span class="status-pill shrink-0"><%= change_request.status.to_s.titleize %></span>
            </span>
          <% end %>
        <% end %>
        <% if @change_requests.empty? %>
          <p class="linear-empty">No Change Requests for this project yet.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
