<% content_for :page_title, @project.title %>
<div class="app-page-actions">
  <div>
    <p class="app-eyebrow"><%= @project.key %> · <%= @project.status %></p>
    <div class="rich-markdown mt-2 max-w-3xl">
      <%= render_markdown(@project.description, empty: "No description.") %>
    </div>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_project_path(@project), class: "app-btn app-btn-muted" %>
    <%= link_to "New issue", new_issue_path(project_id: @project.id), class: "app-btn app-btn-primary" %>
  </div>
</div>
<section class="linear-surface p-5">
  <h2 class="mb-4 font-semibold text-foreground">Issues</h2>
  <%= render "issues/table", issues: @issues %>
</section>
