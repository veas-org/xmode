<% content_for :page_title, "Integrations" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Provider connections</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Connect GitHub, GitLab, and repository contexts used by actions, pipeline runs, and Change Request creation.</p>
  </div>
  <%= link_to new_integration_path, class: "app-btn app-btn-primary" do %>
    <%= lucide_icon("plus", class_name: "app-icon") %>
    <span>Integration</span>
  <% end %>
</div>

<div class="grid gap-5 lg:grid-cols-2">
  <section class="linear-surface">
    <div class="linear-toolbar">
      <div class="flex min-w-0 items-center gap-2">
        <%= lucide_icon("plug", class_name: "app-icon text-muted-foreground") %>
        <h2 class="linear-title">Accounts</h2>
        <span class="linear-count"><%= @integrations.size %></span>
      </div>
    </div>
    <div class="linear-list">
      <% @integrations.each do |integration| %>
        <article class="linear-row">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-muted/45 text-muted-foreground">
            <%= lucide_icon(integration.provider == "github" ? "github" : "plug", class_name: "app-icon") %>
          </span>
          <div class="linear-row-main">
            <p class="linear-row-title"><%= integration.name %></p>
            <div class="linear-row-meta">
              <span><%= integration.provider %></span>
              <span><%= integration.updated_at ? "updated #{time_ago_in_words(integration.updated_at)} ago" : "not synced" %></span>
            </div>
          </div>
          <span class="status-pill"><%= integration.status %></span>
        </article>
      <% end %>
      <% if @integrations.empty? %><p class="linear-empty">No integrations connected.</p><% end %>
    </div>
  </section>
  <section class="linear-surface">
    <div class="linear-toolbar">
      <div class="flex min-w-0 items-center gap-2">
        <%= lucide_icon("git-branch", class_name: "app-icon text-muted-foreground") %>
        <h2 class="linear-title">Repositories</h2>
        <span class="linear-count"><%= @repositories.size %></span>
      </div>
    </div>
    <div class="linear-list">
      <% @repositories.each do |repo| %>
        <article class="linear-row">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-muted/45 text-muted-foreground">
            <%= lucide_icon("folder-git-2", class_name: "app-icon") %>
          </span>
          <div class="linear-row-main">
            <p class="linear-row-title"><%= repo.full_name.presence || repo.name %></p>
            <div class="linear-row-meta">
              <span><%= repo.provider %></span>
              <span><%= repo.default_branch %></span>
              <span><%= repo.url %></span>
            </div>
          </div>
        </article>
      <% end %>
      <% if @repositories.empty? %><p class="linear-empty">Repository sync comes after provider credentials are added.</p><% end %>
    </div>
  </section>
</div>
