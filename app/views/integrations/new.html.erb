<% content_for :page_title, "New integration" %>
<section class="app-card p-6">
  <%= form_with model: @integration, url: integrations_path, class: "space-y-4" do |form| %>
    <%= render "shared/form_errors", object: @integration %>
    <div><%= form.label :provider, class: "app-label" %><%= form.select :provider, IntegrationAccount::PROVIDERS, {}, class: "app-input" %></div>
    <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input", required: true %></div>
    <div><%= form.label :token_ciphertext, "Access token", class: "app-label" %><%= form.password_field :token_ciphertext, class: "app-input" %></div>
    <%= form.submit "Save integration", class: "app-btn app-btn-primary" %>
  <% end %>
</section>
