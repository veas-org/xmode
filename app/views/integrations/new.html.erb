<% content_for :page_title, "New integration" %>
<%= render layout: "shared/side_panel",
      locals: {
        title: "New integration",
        eyebrow: "Manual provider token",
        description: "Use this fallback when a GitHub App or GitLab OAuth-style connection is not available.",
        back_path: integrations_path
      } do %>
  <%= form_with model: @integration, url: integrations_path, class: "space-y-4" do |form| %>
    <%= render "shared/form_errors", object: @integration %>
    <div><%= form.label :provider, class: "app-label" %><%= form.select :provider, IntegrationAccount::PROVIDERS, {}, class: "app-input" %></div>
    <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input", required: true %></div>
    <div>
      <%= form.label :token_ciphertext, "Access token", class: "app-label" %>
      <%= form.password_field :token_ciphertext, class: "app-input" %>
      <p class="mt-2 text-xs leading-5 text-muted-foreground">Prefer the GitHub App flow for GitHub. Manual tokens need repository read access for import, plus write access if xmode should push branches and open Change Requests. GitLab private project import requires api or read_api access.</p>
    </div>
    <%= form.submit "Save integration", class: "app-btn app-btn-primary" %>
  <% end %>
<% end %>
