<section class="mx-auto flex min-h-[calc(100vh-73px)] max-w-md items-center px-5 py-12">
  <div class="app-card w-full p-6">
    <p class="app-eyebrow">Create workspace</p>
    <h1 class="mt-2 text-2xl font-semibold text-white">Start xmode</h1>
    <%= render "shared/form_errors", object: @user %>
    <%= form_with model: @user, url: signup_path, class: "mt-6 space-y-4" do |form| %>
      <div><%= form.label :name, class: "app-label" %><%= form.text_field :name, class: "app-input" %></div>
      <div><%= form.label :email, class: "app-label" %><%= form.email_field :email, class: "app-input", required: true %></div>
      <div><%= form.label :password, class: "app-label" %><%= form.password_field :password, class: "app-input", required: true %></div>
      <div><%= form.label :password_confirmation, class: "app-label" %><%= form.password_field :password_confirmation, class: "app-input", required: true %></div>
      <div><%= label_tag :workspace_name, "Workspace", class: "app-label" %><%= text_field_tag :workspace_name, "xmode Workspace", class: "app-input" %></div>
      <%= form.submit "Create workspace", class: "app-btn app-btn-primary w-full" %>
    <% end %>
  </div>
</section>
