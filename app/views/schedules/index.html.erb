<% content_for :page_title, "Schedules" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Automation schedules</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Time-based automation for recurring maintenance and one-off pipeline runs. Code-changing schedules still create isolated branches and Change Requests.</p>
  </div>
  <%= link_to new_schedule_path, class: "app-btn app-btn-primary" do %>
    <%= lucide_icon("plus", class_name: "app-icon") %>
    <span>Schedule</span>
  <% end %>
</div>

<section class="linear-surface">
  <div class="linear-toolbar">
    <div class="flex min-w-0 items-center gap-2">
      <%= lucide_icon("clock", class_name: "app-icon text-muted-foreground") %>
      <h2 class="linear-title">Scheduled pipelines</h2>
      <span class="linear-count"><%= @schedules.size %></span>
    </div>
  </div>
  <div class="linear-list">
    <% @schedules.each do |schedule| %>
      <%= link_to schedule_path(schedule), class: "linear-row" do %>
        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-muted/45 text-muted-foreground">
          <%= lucide_icon(schedule.kind == "recurring" ? "repeat" : "calendar-clock", class_name: "app-icon") %>
        </span>
        <div class="linear-row-main">
          <p class="linear-row-title"><%= schedule.pipeline_definition.name %></p>
          <div class="linear-row-meta">
            <span><%= schedule.kind %></span>
            <span><%= schedule.schedulable&.try(:title) || schedule.schedulable&.try(:name) || "Workspace" %></span>
            <span><%= schedule.run_at&.strftime("%b %-d, %Y %-I:%M %p") || schedule.cron %></span>
          </div>
        </div>
        <span class="status-pill"><%= schedule.status %></span>
      <% end %>
    <% end %>
    <% if @schedules.empty? %><p class="linear-empty">No schedules yet.</p><% end %>
  </div>
</section>
