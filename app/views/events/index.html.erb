<% content_for :page_title, "Event Inbox" %>

<div class="app-page-actions">
  <div>
    <p class="app-eyebrow">Event intake</p>
    <p class="mt-1 max-w-2xl text-sm text-muted-foreground">Webhook and system events land here before they become issues or trigger matched automation rules.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <span class="status-pill"><%= pluralize(@events.count, "event") %></span>
    <span class="status-pill"><%= @event_counts.fetch(:matched) %> matched</span>
    <span class="status-pill"><%= @event_counts.fetch(:linked) %> linked</span>
  </div>
</div>

<div class="app-detail-grid">
  <section class="linear-surface">
    <div class="linear-toolbar">
      <div class="flex min-w-0 items-center gap-2">
        <%= lucide_icon("bell", class_name: "app-icon text-muted-foreground") %>
        <h2 class="linear-title">Event inbox</h2>
        <span class="linear-count"><%= @events.size %></span>
      </div>
    </div>
    <div class="linear-list">
      <% @event_rows.each do |row| %>
        <% event = row.fetch(:event) %>
        <% matched_rules = row.fetch(:matched_rules) %>
        <%= link_to event_path(event), class: "linear-row" do %>
          <span class="inbox-row-indicator"></span>
          <div class="linear-row-main">
            <p class="linear-row-title"><%= event.title %></p>
            <div class="linear-row-meta">
              <span><%= event.source %></span>
              <span><%= event.event_type %></span>
              <span><%= event.project&.title || "No project" %></span>
              <% if event.issue %>
                <span><%= event.issue.identifier %></span>
              <% end %>
              <span><%= time_ago_in_words(event.created_at) %> ago</span>
            </div>
          </div>
          <div class="hidden flex-wrap justify-end gap-2 md:flex">
            <% if matched_rules.any? %>
              <span class="status-pill"><%= pluralize(matched_rules.size, "rule") %></span>
            <% end %>
            <span class="status-pill"><%= event.severity %></span>
            <span class="status-pill"><%= event.status %></span>
          </div>
        <% end %>
      <% end %>
      <% if @events.empty? %><p class="linear-empty">No events yet.</p><% end %>
    </div>
  </section>

  <aside class="space-y-4">
    <section class="linear-surface">
      <div class="linear-toolbar">
        <div class="flex min-w-0 items-center gap-2">
          <%= lucide_icon("route", class_name: "app-icon text-muted-foreground") %>
          <h2 class="linear-title">Routing rules</h2>
          <span class="linear-count"><%= @rules.size %></span>
        </div>
      </div>
      <div class="linear-list">
        <% @rule_rows.each do |row| %>
          <% rule = row.fetch(:rule) %>
          <article class="linear-row">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-muted/45 text-muted-foreground">
              <%= lucide_icon(rule.active? ? "radio-tower" : "pause-circle", class_name: "app-icon") %>
            </span>
            <div class="linear-row-main">
              <p class="linear-row-title"><%= rule.name %></p>
              <div class="linear-row-meta">
                <span><%= row.fetch(:matched_count) %> matches</span>
                <span><%= rule.pipeline_definition&.name || "No pipeline" %></span>
              </div>
              <div class="mt-2 flex flex-wrap gap-1.5">
                <% row.fetch(:condition_summary).each do |condition| %>
                  <span class="app-badge"><%= condition %></span>
                <% end %>
              </div>
            </div>
            <span class="status-pill shrink-0"><%= rule.active? ? "active" : "paused" %></span>
          </article>
        <% end %>
        <% if @rules.empty? %><p class="linear-empty">No routing rules configured.</p><% end %>
      </div>
    </section>

    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Event flow</h3>
      <div class="mt-3 grid gap-2 text-sm">
        <div class="inbox-property"><span>New intake</span><strong><%= @event_counts.fetch(:new) %></strong></div>
        <div class="inbox-property"><span>Matched to rules</span><strong><%= @event_counts.fetch(:matched) %></strong></div>
        <div class="inbox-property"><span>Linked issues</span><strong><%= @event_counts.fetch(:linked) %></strong></div>
      </div>
      <p class="mt-3 text-sm leading-6 text-muted-foreground">Rules make event-based automation explicit: source and payload conditions choose a pipeline, while unresolved events can still be converted into issues through the event side panel flow.</p>
    </section>
  </aside>
</div>
