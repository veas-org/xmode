<% content_for :page_title, @event.title %>

<div class="app-detail-grid">
  <section class="linear-surface p-5">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="app-eyebrow"><%= @event.source %> · <%= @event.event_type %></p>
        <h2 class="mt-2 text-2xl font-semibold text-foreground"><%= @event.title %></h2>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="status-pill"><%= @event.severity %></span>
        <span class="status-pill"><%= @event.status %></span>
      </div>
    </div>
    <div class="mt-5 grid gap-2 text-sm md:grid-cols-2">
      <div class="inbox-property"><span>Project</span><strong><%= @event.project&.title || "-" %></strong></div>
      <div class="inbox-property"><span>Linked issue</span><strong><%= @event.issue&.identifier || "-" %></strong></div>
    </div>
    <pre class="mt-5 overflow-auto rounded-md bg-background/70 p-4 text-xs text-muted-foreground"><%= JSON.pretty_generate(@event.payload) %></pre>
  </section>
  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Actions</h3>
      <div class="mt-3 space-y-2">
        <% if @event.issue %>
          <%= link_to issue_path(@event.issue), class: "app-btn app-btn-primary w-full" do %>
            <%= lucide_icon("circle-dot", class_name: "app-icon") %>
            <span>Open linked issue</span>
          <% end %>
        <% else %>
          <%= link_to new_issue_path(event_id: @event.id), class: "app-btn app-btn-primary w-full" do %>
            <%= lucide_icon("plus", class_name: "app-icon") %>
            <span>Add issue</span>
          <% end %>
        <% end %>
      </div>
    </section>
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Matched rules</h3>
      <div class="mt-3 space-y-2 text-sm text-muted-foreground">
        <% @rules.each do |rule| %>
          <div class="app-flat-row">
            <p class="font-medium text-foreground"><%= rule.name %></p>
            <p class="mt-1 text-xs"><%= rule.pipeline_definition&.name || "No pipeline" %></p>
          </div>
        <% end %>
        <% if @rules.empty? %><p>No rules matched.</p><% end %>
      </div>
    </section>
  </aside>
</div>
