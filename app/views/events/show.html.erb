<% content_for :page_title, @event.title %>
<div class="grid gap-6 lg:grid-cols-[1fr_320px]">
  <section class="app-card p-5">
    <p class="app-eyebrow"><%= @event.source %> · <%= @event.event_type %></p>
    <h2 class="mt-2 text-2xl font-semibold text-foreground"><%= @event.title %></h2>
    <pre class="mt-5 overflow-auto rounded-md bg-background p-4 text-xs text-muted-foreground"><%= JSON.pretty_generate(@event.payload) %></pre>
  </section>
  <aside class="space-y-4">
    <section class="app-card p-4">
      <h3 class="font-medium text-foreground">Actions</h3>
      <div class="mt-3 space-y-2">
        <%= button_to "Create issue", create_issue_event_path(@event), method: :post, class: "app-btn app-btn-primary w-full" %>
      </div>
    </section>
    <section class="app-card p-4">
      <h3 class="font-medium text-foreground">Matched rules</h3>
      <div class="mt-3 space-y-2 text-sm text-muted-foreground">
        <% @rules.each do |rule| %><p><%= rule.name %></p><% end %>
        <% if @rules.empty? %><p>No rules matched.</p><% end %>
      </div>
    </section>
  </aside>
</div>
