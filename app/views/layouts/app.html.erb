<!DOCTYPE html>
<html lang="en" class="<%= current_user&.theme_preference == "light" ? "" : "dark" %>">
  <head>
    <title><%= content_for(:title) || "xmode" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#07090f">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="app-body min-h-screen bg-background text-foreground antialiased" data-controller="theme">
    <div class="app-shell">
      <%= render "shared/app_sidebar" %>
      <section class="app-main">
        <header class="app-topbar">
          <div class="min-w-0">
            <h1>
              <%= content_for(:page_title) || "xmode" %>
            </h1>
          </div>
          <div class="app-topbar-actions">
            <div class="linear-command app-topbar-command hidden md:flex">
              <span class="flex min-w-0 items-center gap-2">
                <%= lucide_icon("search", class_name: "app-icon") %>
                <span class="truncate">Search issues, projects, runs...</span>
              </span>
              <span class="linear-kbd">Cmd K</span>
            </div>
            <%= link_to new_issue_path, class: "app-btn app-btn-primary hidden sm:inline-flex" do %>
              <%= lucide_icon("plus", class_name: "app-icon") %>
              <span>Issue</span>
            <% end %>
            <button class="app-icon-btn" type="button" data-action="theme#toggle" title="Settings" aria-label="Settings">
              <%= lucide_icon("settings", class_name: "app-icon") %>
            </button>
          </div>
        </header>
        <main class="app-content">
          <%= yield %>
        </main>
      </section>
    </div>
    <%= render "shared/flash" %>
  </body>
</html>
