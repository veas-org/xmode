<!DOCTYPE html>
<html lang="en" class="<%= current_user&.theme_preference == "light" ? "" : "dark" %>">
  <head>
    <title><%= content_for(:title) || "xmode" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#07090f">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="app-body min-h-screen bg-zinc-950 text-zinc-100 antialiased" data-controller="theme">
    <div class="app-shell">
      <%= render "shared/app_sidebar" %>
      <section class="app-main">
        <header class="app-topbar">
          <div>
            <p class="app-eyebrow"><%= current_workspace&.name %></p>
            <h1><%= content_for(:page_title) || "xmode" %></h1>
          </div>
          <div class="app-topbar-actions">
            <button class="app-btn app-btn-muted" type="button" data-action="theme#toggle">Theme</button>
            <%= button_to "Sign out", logout_path, method: :delete, class: "app-btn app-btn-muted" %>
          </div>
        </header>
        <main class="app-content">
          <%= yield %>
        </main>
      </section>
    </div>
    <%= render "shared/flash" %>
  </body>
</html>
