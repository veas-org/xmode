<% active_path = ->(path) do
  target = path.to_s
  target.include?("?") ? request.fullpath == target : request.path == target
end %>
<% nav_sections = [
  [
    "Workspace",
    [
      [ "Inbox", issues_path(view: "inbox"), "inbox" ],
      [ "My Issues", issues_path(view: "my"), "user-circle" ],
      [ "Projects", projects_path, "folder" ],
      [ "Cycles", cycles_path, "calendar" ],
      [ "Views", views_path, "list-filter" ]
    ]
  ],
  [
    "Automation",
    [
      [ "Events", events_path, "bell" ],
      [ "Skills", skills_path, "sparkles" ],
      [ "Pipelines", pipelines_path, "workflow" ],
      [ "Actions", actions_path, "play" ],
      [ "Schedules", schedules_path, "clock" ],
      [ "Change Requests", change_requests_path, "git-pull-request" ]
    ]
  ],
  [
    "Settings",
    [
      [ "Integrations", integrations_path, "plug" ],
      [ "Billing", billing_path, "credit-card" ]
    ]
  ]
] %>
<% user_name = current_user&.display_name.presence || "User" %>
<% user_initials = user_name.split.map { |part| part.first }.join.first(2).upcase %>

<aside class="app-sidebar">
  <%= link_to app_path, class: "mb-4 flex items-center gap-2.5 rounded-md px-2 py-1.5 text-foreground hover:bg-sidebar-accent" do %>
    <span class="app-sidebar-logo">x</span>
    <span class="min-w-0">
      <span class="block truncate text-sm font-semibold">xmode</span>
      <span class="block truncate text-xs text-muted-foreground"><%= current_workspace&.name %></span>
    </span>
  <% end %>

  <nav>
    <% nav_sections.each do |section, links| %>
      <p class="app-sidebar-section"><%= section %></p>
      <div class="mt-1 space-y-0.5">
        <% links.each do |label, path, icon| %>
          <%= link_to path, class: "app-sidebar-link #{'is-active' if active_path.call(path)}" do %>
            <%= lucide_icon(icon, class_name: "app-sidebar-icon") %>
            <span class="truncate"><%= label %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </nav>

  <footer class="app-sidebar-footer">
    <% if current_workspace&.demo? %>
      <div class="app-sidebar-demo">
        <span class="flex min-w-0 items-center gap-2">
          <span class="app-sidebar-demo-dot"></span>
          <span class="truncate">Demo workspace</span>
        </span>
        <span class="shrink-0 text-[11px] text-muted-foreground"><%= current_workspace&.name %></span>
      </div>
    <% end %>

    <div class="app-sidebar-account">
      <span class="app-sidebar-avatar"><%= user_initials %></span>
      <span class="min-w-0 flex-1">
        <span class="app-sidebar-account-name"><%= user_name %></span>
        <span class="app-sidebar-account-meta"><%= current_team&.name || current_workspace&.name || "No team" %></span>
      </span>
      <%= button_to logout_path,
            method: :delete,
            form: { class: "shrink-0" },
            class: "app-sidebar-icon-action",
            title: "Sign out",
            aria: { label: "Sign out" } do %>
        <%= lucide_icon("log-out", class_name: "app-icon") %>
      <% end %>
    </div>
  </footer>
</aside>
