<% if object.errors.any? %>
  <div class="mb-5 rounded-md border border-red-400/30 bg-red-500/10 p-4 text-sm text-red-100">
    <p class="font-medium"><%= pluralize(object.errors.count, "error") %> prevented this from saving.</p>
    <ul class="mt-2 list-disc pl-5">
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
