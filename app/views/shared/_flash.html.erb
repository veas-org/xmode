<% if notice.present? || alert.present? %>
  <div class="fixed bottom-4 right-4 z-50 space-y-2">
    <% if notice.present? %>
      <div class="rounded-md border border-emerald-400/30 bg-emerald-500/15 px-4 py-3 text-sm text-emerald-100 shadow-xl"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="rounded-md border border-red-400/30 bg-red-500/15 px-4 py-3 text-sm text-red-100 shadow-xl"><%= alert %></div>
    <% end %>
  </div>
<% end %>
