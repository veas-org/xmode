<% rows = local_assigns.fetch(:rows, 10) %>
<% label = local_assigns.fetch(:label, field.to_s.humanize) %>
<% placeholder = local_assigns.fetch(:placeholder, nil) %>
<% classes = local_assigns.fetch(:class, "") %>

<div class="markdown-editor <%= classes %>"
     data-controller="markdown-editor"
     data-markdown-editor-placeholder-value="<%= placeholder %>">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <%= form.label field, label, class: "app-label mb-0" %>
    <div class="markdown-toolbar" aria-label="<%= label %> formatting">
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="bold" data-action="markdown-editor#bold" title="Bold" aria-label="Bold"><%= lucide_icon("bold", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="italic" data-action="markdown-editor#italic" title="Italic" aria-label="Italic"><%= lucide_icon("italic", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="heading" data-action="markdown-editor#heading" title="Heading" aria-label="Heading"><%= lucide_icon("heading-2", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="bulletList" data-action="markdown-editor#list" title="Bullet list" aria-label="Bullet list"><%= lucide_icon("list", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="orderedList" data-action="markdown-editor#orderedList" title="Numbered list" aria-label="Numbered list"><%= lucide_icon("list-ordered", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="blockquote" data-action="markdown-editor#quote" title="Quote" aria-label="Quote"><%= lucide_icon("quote", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="codeBlock" data-action="markdown-editor#code" title="Code block" aria-label="Code block"><%= lucide_icon("code", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-markdown-editor-target="button" data-format="link" data-action="markdown-editor#link" title="Link" aria-label="Link"><%= lucide_icon("link", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-action="markdown-editor#toggleSource" title="Markdown source" aria-label="Markdown source"><%= lucide_icon("terminal", class_name: "app-icon") %></button>
      <button type="button" class="markdown-tool-btn" data-action="markdown-editor#togglePreview" title="Preview" aria-label="Preview"><%= lucide_icon("eye", class_name: "app-icon") %></button>
    </div>
  </div>
  <div class="tiptap-surface mt-2 hidden" data-markdown-editor-target="editor"></div>
  <%= form.text_area field,
        rows: rows,
        class: "app-textarea mt-2",
        placeholder: placeholder,
        data: {
          markdown_editor_target: "input",
          action: "input->markdown-editor#refresh"
        } %>
  <div class="markdown-preview rich-markdown mt-3 hidden" data-markdown-editor-target="preview"></div>
</div>
