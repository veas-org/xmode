<% content_for :page_title, @change_request.title %>

<div class="record-detail-layout change-request-record-layout cr-review-layout">
  <main class="record-detail-main cr-review-main">
    <header class="record-doc-hero cr-review-hero">
      <div class="cr-review-hero-top">
        <div class="flex min-w-0 flex-wrap items-center gap-2">
          <span class="linear-count">Review package</span>
          <%= status_icon_pill(@change_request.status, title: @change_request.status.to_s.titleize) %>
          <span class="linear-count"><%= @change_request.external_id.presence || "local draft" %></span>
        </div>
      </div>

      <h2 class="record-detail-page-title"><%= @change_request.title %></h2>
      <p class="cr-review-summary">
        Review the code delta first, then use the compact context and verification evidence to decide whether this branch is ready to open or merge.
      </p>

      <div class="record-detail-page-actions">
        <% if @repository_web_url.present? %>
          <%= link_to @repository_web_url, class: "app-btn app-btn-muted", target: "_blank", rel: "noopener" do %>
            <%= lucide_icon(@change_request.provider == "github" ? "github" : "external-link", class_name: "app-icon") %>
            <span>Repository</span>
          <% end %>
        <% end %>
        <% if @change_request.url.present? %>
          <%= link_to @change_request.url, class: "app-btn app-btn-primary", target: "_blank", rel: "noopener" do %>
            <%= lucide_icon("git-pull-request", class_name: "app-icon") %>
            <span><%= @provider_change_request_label %></span>
          <% end %>
        <% end %>
      </div>
    </header>

    <section class="record-detail-section cr-change-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">What changed</p>
          <h3>Readable diff summary</h3>
          <p class="mt-1 text-sm leading-6 text-muted-foreground">
            <%= pluralize(@changed_files.size, "file") %> changed<% if @diff_sections.any? %>, <%= pluralize(@diff_sections.sum { |section| section[:additions] }, "addition") %>, <%= pluralize(@diff_sections.sum { |section| section[:deletions] }, "deletion") %><% end %>.
          </p>
        </div>
        <span class="linear-count"><%= pluralize(@changed_files.size, "file") %></span>
      </div>

      <% if @diff_sections.any? %>
        <div class="cr-change-list">
          <% @diff_sections.each do |section| %>
            <article class="cr-change-file">
              <div class="cr-change-file-head">
                <span class="linear-count"><%= section[:status] %></span>
                <strong title="<%= section[:path] %>"><%= section[:path] %></strong>
                <span class="cr-change-stats">
                  <span>+<%= section[:additions] %></span>
                  <span>-<%= section[:deletions] %></span>
                </span>
              </div>
              <p><%= section[:note] %></p>
              <% if section[:preview_lines].any? %>
                <div class="cr-change-preview" aria-label="Added lines preview">
                  <% section[:preview_lines].each do |line| %>
                    <code><span>+</span><%= line %></code>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      <% elsif @changed_files.any? %>
        <div class="cr-changed-file-strip">
          <% @changed_files.each do |entry| %>
            <span>
              <strong><%= entry.fetch("label") %></strong>
              <small><%= entry.fetch("path") %></small>
            </span>
          <% end %>
        </div>
      <% else %>
        <p class="linear-empty px-0 py-6 text-left">No changed files were captured for this Change Request.</p>
      <% end %>
    </section>

  </main>

  <aside class="record-detail-side cr-review-side">
    <section class="record-detail-section cr-context-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Context</p>
          <h3>Review context</h3>
        </div>
      </div>
      <div class="cr-context-strip">
        <div>
          <span>Repository</span>
          <strong title="<%= @repository.full_name.presence || @repository.name %>"><%= @repository.full_name.presence || @repository.name %></strong>
        </div>
        <div>
          <span>Branch</span>
          <strong title="<%= @change_request.branch_name %>"><%= @change_request.branch_name.presence || "missing" %></strong>
        </div>
        <div>
          <span>Base</span>
          <strong><%= @repository.default_branch.presence || "main" %></strong>
        </div>
        <div>
          <span>Issue</span>
          <strong><%= @issue&.identifier || "manual" %></strong>
        </div>
        <div>
          <span>Run</span>
          <strong><%= @run ? "##{@run.id} #{ @run.status.to_s.tr('_', ' ') }" : "manual" %></strong>
        </div>
      </div>
    </section>

    <section class="record-detail-section cr-verification-section">
      <div class="record-detail-section-head">
        <div>
          <p class="app-eyebrow">Verification</p>
          <h3><%= @run&.pipeline_definition&.name || "Manual Change Request" %></h3>
        </div>
        <span class="linear-count"><%= pluralize(@steps.size, "step") %></span>
      </div>

      <% if @steps.any? %>
        <div class="cr-verification-list">
          <% @steps.each do |step| %>
            <article class="cr-verification-row">
              <%= status_icon_pill(step.status, title: step.display_status) %>
              <div class="min-w-0">
                <strong><%= step.name %></strong>
                <p>
                  <%= step.output_json["summary"].presence || step.error_message.presence || step.action_definition&.key || "Step recorded." %>
                  <% if step.output_json.key?("changed_files_count") %>
                    <span><%= pluralize(step.output_json["changed_files_count"], "changed file") %></span>
                  <% end %>
                </p>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <p class="linear-empty px-0 py-5 text-left">No run evidence is attached yet. Use the branch and provider links to review manual Change Requests.</p>
      <% end %>
    </section>

    <details class="cr-technical-appendix">
      <summary>
        <span>Technical details</span>
        <small><%= pluralize(@checks.size, "check") %>, <%= pluralize(@artifacts.size, "artifact") %>, <%= pluralize(@logs.size, "recent log") %></small>
      </summary>

      <div class="cr-appendix-grid">
        <section class="cr-appendix-section">
          <h3>Check snapshot</h3>
          <% if @checks.any? %>
            <dl class="cr-appendix-list">
              <% @checks.each do |key, value| %>
                <div>
                  <dt><%= key.to_s.humanize %></dt>
                  <dd><%= value.is_a?(Array) || value.is_a?(Hash) ? JSON.generate(value) : value.to_s %></dd>
                </div>
              <% end %>
            </dl>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No checks captured yet.</p>
          <% end %>
        </section>

        <section class="cr-appendix-section">
          <h3>Artifacts</h3>
          <% if @artifacts.any? %>
            <div class="cr-appendix-items">
              <% @artifacts.each do |artifact| %>
                <% preview = artifact_text_preview(artifact, max_bytes: 8_000) %>
                <details class="cr-appendix-item">
                  <summary>
                    <span><%= artifact.name %></span>
                    <small><%= artifact.byte_size.present? ? number_to_human_size(artifact.byte_size) : artifact.content_type.presence || "saved" %></small>
                  </summary>
                  <% if preview.present? && artifact.content_type == "text/markdown" %>
                    <div class="record-artifact-preview rich-markdown mt-3">
                      <%= render_markdown(preview) %>
                    </div>
                  <% elsif preview.present? && (artifact.content_type&.start_with?("text/") || artifact.content_type == "application/json" || artifact.content_type == "text/x-patch") %>
                    <pre class="record-artifact-preview mt-3 overflow-auto rounded-md bg-muted/35 p-3 text-xs text-muted-foreground"><%= preview %></pre>
                  <% else %>
                    <p class="mt-2 text-xs text-muted-foreground">Preview unavailable.</p>
                  <% end %>
                </details>
              <% end %>
            </div>
          <% else %>
            <p class="linear-empty px-0 py-3 text-left">No artifacts attached.</p>
          <% end %>
        </section>

        <% if @logs.any? %>
          <section class="cr-appendix-section cr-appendix-section-wide">
            <h3>Recent logs</h3>
            <div class="cr-log-list">
              <% @logs.each do |log| %>
                <article>
                  <%= status_icon_pill(log.level, title: log.level.to_s.titleize) %>
                  <span><%= log.message %></span>
                  <small><%= time_ago_in_words(log.created_at) %> ago</small>
                </article>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </details>
  </aside>
</div>
