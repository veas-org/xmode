<% content_for :page_title, @change_request.title %>

<div class="app-detail-grid">
  <section class="linear-surface p-5">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="app-eyebrow"><%= @change_request.provider %> · <%= @change_request.repository_connection.full_name.presence || @change_request.repository_connection.name %></p>
        <h2 class="mt-2 text-2xl font-semibold text-foreground"><%= @change_request.title %></h2>
      </div>
      <span class="status-pill"><%= @change_request.status %></span>
    </div>
    <dl class="mt-5 grid gap-2 text-sm md:grid-cols-2">
      <div class="inbox-property"><dt>Branch</dt><dd><strong><%= @change_request.branch_name %></strong></dd></div>
      <div class="inbox-property"><dt>Issue</dt><dd><strong><%= @change_request.issue&.identifier || "-" %></strong></dd></div>
      <div class="inbox-property"><dt>Run</dt><dd><strong><%= @change_request.pipeline_run ? "##{@change_request.pipeline_run.id}" : "-" %></strong></dd></div>
      <div class="inbox-property"><dt>External id</dt><dd><strong><%= @change_request.external_id.presence || "-" %></strong></dd></div>
    </dl>
    <% if @change_request.url.present? %>
      <%= link_to @change_request.url, class: "app-btn app-btn-primary mt-5", target: "_blank", rel: "noopener" do %>
        <%= lucide_icon("external-link", class_name: "app-icon") %>
        <span>Open Change Request</span>
      <% end %>
    <% end %>
  </section>
  <aside class="space-y-4">
    <section class="linear-surface p-4">
      <h3 class="font-medium text-foreground">Checks</h3>
      <pre class="mt-3 max-h-96 overflow-auto rounded-md bg-background/70 p-3 text-xs text-muted-foreground"><%= JSON.pretty_generate(@change_request.checks) %></pre>
    </section>
  </aside>
</div>
