<% content_for :page_title, "Change Requests" %>

<div class="ops-page">
  <header class="ops-hero">
    <div class="min-w-0">
      <p class="app-eyebrow">Review boundary</p>
      <h1>Change Requests</h1>
      <p>Every code-changing automation ends with a branch, provider record, checks, and links back to issue and run context.</p>
      <div class="ops-summary" aria-label="Change Request summary">
        <span><strong><%= @change_request_counts.fetch(:total) %></strong> requests</span>
        <span><strong><%= @change_request_counts.fetch(:open) %></strong> open</span>
        <span><strong><%= @change_request_counts.fetch(:linked_runs) %></strong> run-linked</span>
        <span><strong><%= @change_request_counts.fetch(:linked_issues) %></strong> issue-linked</span>
      </div>
    </div>
  </header>

  <section class="ops-section">
    <div class="ops-section-head">
      <div>
        <p class="app-eyebrow">Review queue</p>
        <h2>Grouped by status</h2>
      </div>
      <span class="linear-count"><%= @change_requests.size %></span>
    </div>

    <div class="ops-group-list">
      <% @status_groups.each do |status, requests| %>
        <section class="ops-group">
          <div class="ops-group-head">
            <h3><%= status.to_s.titleize %></h3>
            <span class="linear-count"><%= requests.size %></span>
          </div>
          <div class="ops-list">
            <% requests.each do |cr| %>
              <%= link_to change_request_path(cr), class: "ops-row" do %>
                <%= status_icon_pill(cr.status, title: cr.status.to_s.titleize) %>
                <span class="record-point-main">
                  <span class="record-point-title"><%= cr.title %></span>
                  <span class="record-point-meta">
                    <span><%= cr.provider %></span>
                    <span><%= cr.repository_connection.full_name.presence || cr.repository_connection.name %></span>
                    <span class="break-all"><%= cr.branch_name %></span>
                    <% if cr.issue %><span><%= cr.issue.identifier %></span><% end %>
                  </span>
                </span>
                <span class="linear-count"><%= cr.external_id.presence || "draft" %></span>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
      <% if @change_requests.empty? %>
        <p class="linear-empty px-0 py-6 text-left">No Change Requests yet.</p>
      <% end %>
    </div>
  </section>
</div>
